        customServerList.id = "customServerList";
        customServerList.className = "custom-scroll list-container";

        serverSection.appendChild(customServerList);
        sectionContainer.appendChild(serverSection);

        this.setupServerList(customServerList);

        this.elements.menuContainer.appendChild(sectionContainer);

        if (this.elements.serverBrowser) {
            this.elements.serverBrowser.style.display = "none";
        }
