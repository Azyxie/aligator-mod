class Projectile {
    init(indx, x, y, dir, spd, dmg, rng, scl, owner){
        this.active = true;
        this.indx = indx;

        this.x = x;
        this.y = y;

        this.lastX = x;
        this.lastY = y;

        this.xVel = x;
        this.yVel = y;

        this.xRender = x;
        this.yRender = y;
        this.predictDmg = 0;

        this.dir = dir;
        this.speed = spd;
        this.dmg = dmg;
        this.scale = scl;
        this.range = rng;
        this.owner = owner;
        this.sentTo = {};
    };

    update(delta){
        if(this.active){
            var tmpSpeed = this.speed * delta;

            this.lastX = this.x;
            this.lastY = this.y;

            this.x += tmpSpeed * Math.cos(this.dir);
            this.y += tmpSpeed * Math.sin(this.dir);

            this.xVel = this.x * 2 - this.lastX;
            this.yVel = this.y * 2 - this.lastY;

            this.range -= tmpSpeed;
            if(this.range <= 0){
                this.x += this.range * Math.cos(this.dir);
                this.y += this.range * Math.sin(this.dir);

                this.active = false;
            }
        }
    }

    animate(delta){
        var tmpSpeed = this.speed * delta;

        this.xRender += tmpSpeed * Math.cos(this.dir);
        this.yRender += tmpSpeed * Math.sin(this.dir);
    }
}

class ProjectileManager {
    // ADD PROJECTILE PACKET -> REMOVE PROJECTILE PACKET
    constructor(){
        this.projectiles = [];
        this.removedProjectiles = [];
    }

    addProjectile(x, y, dir, range, speed, indx, owner, ignoreObj, layer){
        const tmpData = items.projectiles[indx];
        let tmpProj;

        for(const projectile of this.projectiles){
            if(projectile.active) continue;

            tmpProj = projectile;
            break;
        }

        if(!tmpProj){
            tmpProj = new Projectile();
            tmpProj.sid = this.projectiles.length;
            this.projectiles.push(tmpProj);
        }

        tmpProj.init(indx, x, y, dir, speed, tmpData.dmg, range, tmpData.scale, owner);
        tmpProj.ignoreObj = ignoreObj;
        tmpProj.layer = layer || tmpData.layer;
        tmpProj.src = tmpData.src;
        return tmpProj;
    };

    updateProjectiles(){
        for(const projectile of this.projectiles){
            projectile.isNew = false;
            projectile.update(config.tickRate);
        }
    }

    add(data){
        const [x, y, dir, range, speed, indx, layer, sid] = data;
        const projectile = this.addProjectile(x, y, dir, range, speed, indx, null, null, layer);

        projectile.sid = sid;
        projectile.isNew = true;
    }

    remove(data){
        const [sid, range] = data;
        for(const projectile of this.projectiles){
            if(projectile.sid != sid) continue;
            projectile.range = range;

            this.removedProjectiles.push(projectile);
            objectDamageManager.addShoot(projectile);

            break;
        }
    }
}

class AI {
    constructor(sid){
        this.sid = sid;
        this.isAI = true;
        this.nameIndex = UTILS.randInt(0, config.cowNames.length-1);

        this.animTime = 0;
        this.dirPlus = 0;
        this.targetAngle = 0;
        this.animSpeed = 600;

        var tmpRatio = 0;
        var animIndex = 0;

        this.animate = function(delta) {
            if (this.animTime > 0) {
                this.animTime -= delta;
                if (this.animTime <= 0) {
                    this.animTime = 0;
                    this.dirPlus = 0;
                    tmpRatio = 0;
                    animIndex = 0;
                } else {
                    if (animIndex == 0) {
                        tmpRatio += delta / (this.animSpeed * config.hitReturnRatio);
                        this.dirPlus = UTILS.lerp(0, this.targetAngle, Math.min(1, tmpRatio));
                        if (tmpRatio >= 1) {
                            tmpRatio = 1;
                            animIndex = 1;
                        }
                    } else {
                        tmpRatio -= delta / (this.animSpeed * (1 - config.hitReturnRatio));
                        this.dirPlus = UTILS.lerp(0, this.targetAngle, Math.max(0, tmpRatio));
                    }
                }
            }
        };

        this.startAnim = function() {
            this.animTime = this.animSpeed = 600;
            this.targetAngle = Math.PI * 0.8;
            tmpRatio = 0;
            animIndex = 0;
        };

        // INIT:
        this.init = function(x, y, dir, index, data) {
