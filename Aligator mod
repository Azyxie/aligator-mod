        this.xVel = this.x * 2 - this.lastX;
        this.yVel = this.y * 2 - this.lastY;
    }

    isAlly(sid){
        for(let i = 0;i < this.alliancePlayers.length;i += 2){ 
            if(this.alliancePlayers[i] == sid) return true;
        }

        return false;
    }

    canSee(other, config) {
        if (!other) return false;
        const dx = Math.abs(other.x - this.x) - other.scale;
        const dy = Math.abs(other.y - this.y) - other.scale;
        return (
            dx <= (config.maxScreenWidth / 2) * 1.3 &&
            dy <= (config.maxScreenHeight / 2) * 1.3
        );
    }

    distanceTo(player) {
        return UTILS.getDistance(this.x, this.y, player.x, player.y);
    }

    velocityDistanceTo(player) {
        return UTILS.getDistance(this.xVel, this.yVel, player.xVel, player.yVel);
    }

    angleTo(player) {
        return Math.atan2(player.y - this.y, player.x - this.x);
    }
