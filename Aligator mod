        if(this.group != undefined){
            this.layer = this.group.layer;
        } else if(this.type == 0){
            this.layer = 3;
        } else if(this.type == 2){
            this.layer = 0;
        } else if(this.type == 4){
            this.layer = -1;
        }
        this.colDiv = data.colDiv||1;
        this.blocker = data.blocker;
        this.ignoreCollision = data.ignoreCollision;
        this.dontGather = data.dontGather;
        this.hideFromEnemy = data.hideFromEnemy;
        this.friction = data.friction;
        this.projDmg = data.projDmg;
        this.dmg = data.dmg;
        this.pDmg = data.pDmg;
        this.pps = data.pps;
        this.zIndex = data.zIndex||0;
        this.turnSpeed = data.turnSpeed;
        this.req = data.req;
        this.trap = data.trap;
        this.healCol = data.healCol;
        this.teleport = data.teleport;
        this.boostSpeed = data.boostSpeed;
        this.projectile = data.projectile;
        this.shootRange = data.shootRange;
        this.shootRate = data.shootRate;
        this.shootCount = this.shootRate;
        this.spawnPoint = data.spawnPoint;
    };

    changeHealth(amount, doer){
        this.health += amount;
        return (this.health <= 0);
    };

    getScale(sM, ig){
        sM = sM||1;
        return this.scale * ((this.isItem||this.type==2||this.type==3||this.type==4) // type 3 trees?
                             ?1:(0.6*sM)) * (ig?1:this.colDiv);
    };

    visibleToPlayer(player){
        return !(this.hideFromEnemy) || (this.owner && (this.owner == player || (this.owner.team && player.team == this.owner.team)));
    };

    update(delta){
        if(!this.active) return;

        if(this.xWiggle) this.xWiggle *= Math.pow(0.99, delta);
        if(this.yWiggle) this.yWiggle *= Math.pow(0.99, delta);

        if(this.turnSpeed) this.dir += this.turnSpeed * delta;
    };
}

class Move extends ModFeature {
    constructor(){
        super();
        this.predictAngle = null;
        this.lastCounterStrife = false;
        this.lastAngle = null;
        this.predict = [];
        this.vectors = {
            87: [0,-1],
            83: [0,1],
            65: [-1,0],
            68: [1,0]
        };
    }

    getWasd(keys){
        this.predictAngle = null;

        // CONTROLLED MOVE
        this.predict = [];
        for(let i in keys) if(keys[i] && this.vectors[i]) this.predict.push(this.vectors[i]);

        if(this.predict.length > 0){
            let moveX=0, moveY=0;
            for(let v of this.predict){moveX+=v[0]; moveY+=v[1];}
            if(moveX!=0||moveY!=0) this.predictAngle = Math.atan2(moveY, moveX);
        }
    }

    safeWalk() {
        const { myPlayer } = playerManager;
        if(!settings.safeWalk) return;
        if(myPlayer.trap) return;

        const simulate = (moveAngle) => {
            const savedMyPlayer = { ...myPlayer };
            const savedTickParams = myPlayer.tickParams ? { ...myPlayer.tickParams } : null;
            const savedLastTickParams = myPlayer.lastTickParams ? { ...myPlayer.lastTickParams } : null;

            const customUpdateTick = function (angle) {
                playerVelocityPosition.update(angle, config.tickRate, myPlayer, false);
                myPlayer.x = playerVelocityPosition.x;
                myPlayer.y = playerVelocityPosition.y;
                myPlayer.lastTickParams = myPlayer.tickParams;
                return playerVelocityPosition.predictSpikeDamage;
            };

            let hitSpike = false;
            let spikes = [];

            const spikeDamage = customUpdateTick(moveAngle);
            if (spikeDamage) {
                hitSpike = true;
                spikes = playerVelocityPosition.spikes;
            } else {
                while (playerVelocityPosition.xVel || playerVelocityPosition.yVel) {
                    const coastDamage = customUpdateTick(null);
                    if (coastDamage) {
                        hitSpike = true;
                        spikes = playerVelocityPosition.spikes;
                        break;
                    }
                }
            }

            // Restore
            for (const key in savedMyPlayer) { myPlayer[key] = savedMyPlayer[key]; }
            myPlayer.tickParams = savedTickParams;
            myPlayer.lastTickParams = savedLastTickParams;

            return { hitSpike, spikes };
        };

        const { hitSpike, spikes } = simulate(this.predictAngle);

        if (hitSpike) {
            const stopResult = simulate(null);
            if (!stopResult.hitSpike) {
                this.predictAngle = null;
            } else {
                if (spikes.length > 0) {
                    let avgX = 0, avgY = 0;
                    for (let spike of spikes) {
                        avgX += spike.x;
                        avgY += spike.y;
                    }
                    avgX /= spikes.length;
                    avgY /= spikes.length;
                    const dodgeAngle = UTILS.getDirection(avgX, avgY, myPlayer.x, myPlayer.y) + Math.PI;
                    const dodgeResult = simulate(dodgeAngle);
                    if (!dodgeResult.hitSpike) {
                        this.predictAngle = dodgeAngle;
                    } else {
                        this.predictAngle = null;
                    }
                }
            }
        }
    }

    send(socket){
        if(this.predictAngle != this.lastAngle){
            game.sendMoveDir(this.predictAngle);
            this.lastAngle = this.predictAngle;
        }
    }
}

class ObjectManager {
    constructor(){
        this.objects = [];
        this.visibleObjects = [];
        this.allySpikes = [];
    }

    add(sid, x, y, dir, s, type, data, setSID, owner) {
        let tmpObj = null;
        for(const object of this.objects){
            if(object.sid != sid) continue;

            tmpObj = object;
            break;
        }

        if(!tmpObj){
            tmpObj = new GameObject(sid);
            this.objects.push(tmpObj);
        }

        if(setSID) tmpObj.sid = sid;
        tmpObj.init(x, y, dir, s, type, data, owner);
    };

    findObjectBySid(sid) {
        for (var i = 0; i < this.objects.length; ++i) {
            if (this.objects[i].sid == sid) {
                return this.objects[i];
            }
        } return null;
    }

    disableBySid(sid) {
        for(const object of this.objects){
            if(object.sid != sid) continue;
            this.objects.splice(this.objects.indexOf(object), 1);
            break;
        }
    };

    isEnemyObject(player, object) {
        return object.owner && object.owner.sid != player.sid && !player.isAlly(object.owner.sid);
    }

    isSpike(object) {
        return [6, 7, 8, 9].includes(object.id);
    }

    isTrap(object) {
        return [15].includes(object.id);
    }

    isTeleporter(object) {
        return [22].includes(object.id);
    }

    removeAllItems(sid) {
        const objects = this.objects.filter((object) => object.owner && object.owner.sid == sid);
        for(const object of objects){
            this.objects.splice(this.objects.indexOf(object), 1);
        }
    };

    updateVisibleObjects(myPlayer, distance){
        this.visibleObjects = this.objects.filter((object) => object.active && UTILS.getDistance(object.x, object.y, myPlayer.x, myPlayer.y) <= distance);
        this.allySpikes = this.visibleObjects.filter(obj => !this.isEnemyObject(myPlayer, obj) && this.isSpike(obj));
    }

    checkItemLocation(x, y, s, sM, indx, ignoreWater, objects) {
        if(!ignoreWater && indx != 18 && y >= (config.mapScale / 2) - (config.riverWidth / 2) && y <= (config.mapScale / 2) + (config.riverWidth / 2)) return false;
        for(const object of objects){
            if(!object.active) continue;

            const blockS = (object.blocker ? object.blocker : object.getScale(sM, object.isItem));
            if(UTILS.getDistance(x, y, object.x, object.y) < (s + blockS )) return false;
        }

        return true;
    };

    killObjects(sid) {
        objectManager.removeAllItems(sid);
    }

    killObject(sid) {
        objectManager.disableBySid(sid);
    }

    wiggleObject(dir, sid) {
        const tmpObj = this.findObjectBySid(sid);
        if (tmpObj) {
            objectDamageManager.damageObjects.push(tmpObj);

            tmpObj.xWiggle += config.gatherWiggle * Math.cos(dir);
            tmpObj.yWiggle += config.gatherWiggle * Math.sin(dir);
        }
    }
}

class Player { 
    constructor(){
        this.isPlayer = true;

        this.team = null;
        this.itemCounts = {};
        this.lastHealTick = 0;

        this.tails = [1];
        this.skins = [1];


        this.alliancePlayers = []; 
        this.animTime = 0;
        this.dirPlus = 0;
        this.targetAngle = 0;
        this.animSpeed = 100;
        let tmpRatio = 0;
        let animIndex = 0;

        this.animate = function(delta) {
            if (this.animTime > 0) {
                this.animTime -= delta;
                if (this.animTime <= 0) {
                    this.animTime = 0;
                    this.dirPlus = 0;
                    tmpRatio = 0;
                    animIndex = 0;
                } else {
                    if (animIndex === 0) {
                        tmpRatio += delta / (this.animSpeed * config.hitReturnRatio);
                        this.dirPlus = UTILS.lerp(0, this.targetAngle, Math.min(1, tmpRatio));
                        if (tmpRatio >= 1) {
                            tmpRatio = 1;
                            animIndex = 1;
                        }
                    } else {
                        tmpRatio -= delta / (this.animSpeed * (1 - config.hitReturnRatio));
                        this.dirPlus = UTILS.lerp(0, this.targetAngle, Math.max(0, tmpRatio));
                    }
                }
            }
        };

        this.startAnim = function(didHit, index) {
            this.animTime = this.animSpeed = items.weapons[index].speed;
            this.targetAngle = (didHit ? -config.hitAngle : -Math.PI);
            tmpRatio = 0;
            animIndex = 0;
        };
