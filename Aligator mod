    cacheDOM() {
        this.root = document.querySelector('.menu-root');
        this.content = document.querySelector('.menu-content');
        this.headerTitle = document.querySelector('.header-title');
        this.searchInput = document.querySelector('.search-input');
        this.navItems = document.querySelectorAll('.nav-item');
    }

    bindEvents() {
        document.addEventListener('keydown', e => {
            if (e.code === 'Insert' || e.code === 'Escape') this.root.classList.toggle('active');
        });

        this.navItems.forEach(btn => {
            btn.onclick = () => {
                this.searchInput.value = '';
                this.navItems.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                this.render(btn.dataset.tab);
            };
        });

        this.searchInput.addEventListener('input', (e) => this.handleSearch(e.target.value));

        document.addEventListener('click', (e) => {
            if (!e.target.closest('.select-container')) {
                document.querySelectorAll('.select-body').forEach(el => el.classList.remove('open'));
                document.querySelectorAll('.select-head').forEach(el => el.classList.remove('active'));
            }
        });
    }

    handleSearch(query) {
        query = query.toLowerCase().trim();
        if (!query) return this.render(this.currentTab);

        const itemsFound = [];
        Object.values(this.menuConfig).forEach(sections => {
            sections.forEach(sec => {
                sec.items.forEach(item => {
                    if (item.name && item.name.toLowerCase().includes(query)) itemsFound.push(item);
                });
            });
        });

        if (itemsFound.length > 0) {
            this.render(null, [{ title: "Search Results", items: itemsFound }]);
        } else {
            this.content.innerHTML = `<div style="padding:20px; color:var(--text-dim); font-size:13px; grid-column: 1 / -1; text-align: center; width: 100%;">No matches found.</div>`;
        }
    }

    render(tab, searchResults = null) {
        this.content.innerHTML = '';

        let sections;
        if (searchResults) {
            this.headerTitle.innerText = "Search Results";
            sections = searchResults;
        } else {
            this.currentTab = tab;
            const tabNames = { keybinds: 'Keybind Settings', combat: 'Combat Settings', defense: 'Defense Settings', placers: 'Placers Settings', utilities: 'Utilities Settings', misc: 'Miscellaneous', visuals: 'Visuals Settings', menu: 'Menu Settings' };
            this.headerTitle.innerText = tabNames[tab] || 'Settings';
            sections = this.menuConfig[tab] || [];
        }

        if (!sections.length) {
            this.content.innerHTML = `<div style="padding:20px; color:var(--text-dim); font-size:13px; grid-column: 1 / -1; text-align: center; width: 100%;">No content yet</div>`;
            return;
        }

        sections.forEach(sec => this.createCard(sec));
    }

    createCard(section) {
        const card = document.createElement('div');
        card.className = 'menu-card';

        const title = document.createElement('div');
        title.className = 'card-title';
        title.innerText = section.title;
        card.appendChild(title);

        const itemsContainer = document.createElement('div');
        section.items.forEach(item => this.createControl(item, itemsContainer));
        card.appendChild(itemsContainer);

        this.content.appendChild(card);
    }

    createControl(item, container) {
        const creators = {
            toggle: this.renderToggle,
            slider: this.renderSlider,
            input: this.renderInput,
            keybind: this.renderKeybind,
            theme_select: this.renderThemeSelect,
            selection: this.renderSelection
        };
        if (creators[item.type]) creators[item.type].call(this, item, container);
    }

    renderToggle(item, container) {
        const row = document.createElement('div');
        row.className = 'feature-row';
        row.innerHTML = `<span class="feat-label">${item.name}</span>`;

        const switchEl = document.createElement('div');
        switchEl.className = `switch ${settings[item.id] ? 'active' : ''}`;
        switchEl.innerHTML = `<div class="knob"></div>`;

        switchEl.onclick = () => {
            settings[item.id] = !settings[item.id];
            switchEl.classList.toggle('active');
            this.saveSettings();
        };

        row.appendChild(switchEl);
        container.appendChild(row);
    }

    renderSlider(item, container) {
        const row = document.createElement('div');
        row.className = 'feature-row stacked';
        row.innerHTML = `<span class="feat-label">${item.name}</span>`;

        const wrap = document.createElement('div');
        wrap.className = 'slider-wrapper';

        const input = document.createElement('input');
        input.type = 'range';
        input.min = item.min;
        input.max = item.max;
        input.value = settings[item.id];

        const valDisplay = document.createElement('span');
        valDisplay.className = 'slider-val';
        valDisplay.innerText = settings[item.id];

        input.oninput = (e) => {
            settings[item.id] = parseInt(e.target.value);
            valDisplay.innerText = settings[item.id];
            this.saveSettings();
        };

        wrap.append(input, valDisplay);
        row.appendChild(wrap);
        container.appendChild(row);
    }

    renderInput(item, container) {
        const row = document.createElement('div');
        row.className = 'feature-row stacked';
        row.innerHTML = `<span class="feat-label">${item.name}</span>`;

        const wrap = document.createElement('div');
        wrap.className = 'input-wrapper';

        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'text-input-styled';
        input.value = settings[item.id];
        input.oninput = (e) => {
            settings[item.id] = e.target.value;
            this.saveSettings();
        };

        wrap.appendChild(input);
        row.appendChild(wrap);
        container.appendChild(row);
    }

    renderKeybind(item, container) {
        const row = document.createElement('div');
        row.className = 'feature-row';
        row.innerHTML = `<span class="feat-label">${item.name}</span>`;

        const btn = document.createElement('button');
        btn.className = 'keybind-btn';
        btn.innerText = settings[item.id];

        btn.onclick = () => {
            btn.innerText = "...";
            btn.classList.add('recording');

            const keyHandler = (e) => {
                e.preventDefault();
                e.stopPropagation();
                let code = e.code.replace('Key', '').replace('Digit', '');

                if (e.key === 'Escape') {
                    btn.innerText = settings[item.id];
                } else {
                    settings[item.id] = code.toUpperCase();
                    btn.innerText = settings[item.id];
                    this.saveSettings();
                }

                btn.classList.remove('recording');
                document.removeEventListener('keydown', keyHandler);
            };
            document.addEventListener('keydown', keyHandler);
        };

        row.appendChild(btn);
        container.appendChild(row);
    }

    renderSelection(item, container) {
        const row = document.createElement('div');
        row.className = 'feature-row stacked';
        row.innerHTML = `<span class="feat-label">${item.name}</span>`;

        const wrap = document.createElement('div');
        wrap.className = 'select-container';

        const head = document.createElement('div');
        head.className = 'select-head';
        head.innerHTML = `<span>${settings[item.id]}</span><svg class="select-arrow" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6l-6-6 1.41-1.41z"/></svg>`;

        const body = document.createElement('div');
        body.className = 'select-body';

        item.options.forEach(opt => {
            const el = document.createElement('div');
            el.className = `select-opt ${settings[item.id] === opt ? 'selected' : ''}`;
            el.innerText = opt;
            el.onclick = () => {
                settings[item.id] = opt;
                head.querySelector('span').innerText = opt;
                body.querySelectorAll('.select-opt').forEach(o => o.classList.remove('selected'));
                el.classList.add('selected');
                body.classList.remove('open');
                head.classList.remove('active');
                this.saveSettings();
            };
            body.appendChild(el);
        });

        head.onclick = (e) => {
            e.stopPropagation();
            document.querySelectorAll('.select-body').forEach(el => { if (el !== body) el.classList.remove('open') });
            document.querySelectorAll('.select-head').forEach(el => { if (el !== head) el.classList.remove('active') });
            body.classList.toggle('open');
            head.classList.toggle('active');
        };

        wrap.append(head, body);
        row.appendChild(wrap);
        container.appendChild(row);
    }

    renderThemeSelect(item, container) {
        const themes = [
            { name: 'Default', cls: 'tb-def', val: '' },
            { name: 'Nightvision', cls: 'tb-nvg', val: 't-nvg' },
            { name: 'Glacier', cls: 'tb-ice', val: 't-ice' },
            { name: 'Crimson', cls: 'tb-red', val: 't-red' },
            { name: 'Amethyst', cls: 'tb-void', val: 't-void' }
        ];

        const grid = document.createElement('div');
        grid.className = 'theme-grid';

        themes.forEach(t => {
            const btn = document.createElement('div');
            btn.className = `theme-btn ${t.cls} ${settings[item.id] === t.val ? 'active' : ''}`;
            btn.title = t.name;

            btn.onclick = () => {
                grid.querySelectorAll('.theme-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                this.root.classList.remove('t-nvg', 't-ice', 't-red', 't-void');
                if (t.val) this.root.classList.add(t.val);
                settings[item.id] = t.val;
                this.saveSettings();
            };
            grid.appendChild(btn);
        });
        container.appendChild(grid);
    }
}

class Autogather {
    constructor() {
        this.state = false;
        this.sendGather = false;
        this.pendingOff = false;
    }

    needAutoGather() {
        const {myPlayer} = playerManager;
        return game.ePress || combat.state || autobreak.state;
    }

    isWeaponReady() {
        const {myPlayer} = playerManager;
        const primaryReady = myPlayer.primaryReload === 1;
        const secondaryReady = myPlayer.weapons[1] !== undefined ?
            myPlayer.secondaryReload === 1 : true;
        return primaryReady && secondaryReady;
    }

    updateState() {
        this.sendGather = false;
        
        if (this.needAutoGather() && !this.state) {
            this.state = true;
            this.sendGather = true;
            this.pendingOff = false;
        } else if (!this.needAutoGather() && this.state) {
            this.pendingOff = true;
        }
        
        if (this.pendingOff && this.isWeaponReady()) {
            this.state = false;
            this.sendGather = true;
            this.pendingOff = false;
        }
    }

    updateDefenseAnti() {
    if (this.state && cosmetics.safeSoldier) {
        if (this.isWeaponReady()) {
            this.state = false;
            this.sendGather = !this.sendGather; // Toggle
            this.pendingOff = false;
        }
    }
}

    send() {
        if(this.sendGather) {
            game.sendAutoGather();
        }
    }
}

