class Zoom {
     constructor(visualsManager, options = {}) {
        this.visualsManager = visualsManager;
        this.config = config;
        this.factor = 1.0;
        this.zoomSpeed = options.zoomSpeed || 0.1;
        this.minFactor = options.minFactor || 0.5;
        this.maxFactor = options.maxFactor || 2.0;

        this.originalMaxScreenWidth = config.maxScreenWidth;
        this.originalMaxScreenHeight = config.maxScreenHeight;

        this.screenWidth = 0;
        this.screenHeight = 0;
        this.pixelDensity = window.devicePixelRatio || 1;

        this.gameCanvas = null;
        this.mainContext = null;
    }

    initialize(canvas, context) {
        if (!canvas || !context) {
            console.error('Canvas or context is undefined');
            return;
        }

        this.gameCanvas = canvas;
        this.mainContext = context;
        this.resize();
        this.attachEventListeners();
    }

    resetZoom() {
        const newW = this.originalMaxScreenWidth * this.factor;
        const newH = this.originalMaxScreenHeight * this.factor;

        config.maxScreenWidth = newW;
        config.maxScreenHeight = newH;

        this.resize();
    }

    resize() {
        this.screenWidth = window.innerWidth;
        this.screenHeight = window.innerHeight;

        const scaleFillNative = Math.max(
            this.screenWidth / config.maxScreenWidth,
            this.screenHeight / config.maxScreenHeight
        ) * this.pixelDensity;

        this.gameCanvas.width = this.screenWidth * this.pixelDensity;
        this.gameCanvas.height = this.screenHeight * this.pixelDensity;
        this.gameCanvas.style.width = this.screenWidth + "px";
        this.gameCanvas.style.height = this.screenHeight + "px";

        this.mainContext.setTransform(
            scaleFillNative, 0,
            0, scaleFillNative,
            (this.screenWidth * this.pixelDensity - (config.maxScreenWidth * scaleFillNative)) / 2,
            (this.screenHeight * this.pixelDensity - (config.maxScreenHeight * scaleFillNative)) / 2
        );
    }

    handleWheel(e) {
        const {myPlayer} = playerManager;
        if(!myPlayer) return;
        const checkElementHover = (elementId) => {
            const element = document.getElementById(elementId);
            if (element && !element.classList.contains('settings-hidden')) {
                const rect = element.getBoundingClientRect();
                return (
                    e.clientX >= rect.left &&
                    e.clientX <= rect.right &&
                    e.clientY >= rect.top &&
                    e.clientY <= rect.bottom
                );
            }
            return false;
        };

        if (checkElementHover('storeHolder') || checkElementHover('allianceHolder')) {
            return; // Let browser handle scroll normally
        }

        if (e.deltaY < 0) {
            this.factor = Math.max(this.factor - this.zoomSpeed, this.minFactor);
        } else {
            this.factor = Math.min(this.factor + this.zoomSpeed, this.maxFactor);
        }

        this.resetZoom();
    }

    attachEventListeners() {
        window.addEventListener('resize', () => this.resize());
        window.addEventListener('wheel', (e) => this.handleWheel(e), { passive: false });
    }

    getZoomFactor() {
        return this.factor;
    }

    setZoomFactor(factor) {
        this.factor = Math.max(this.minFactor, Math.min(this.maxFactor, factor));
        this.resetZoom();
    }
}

