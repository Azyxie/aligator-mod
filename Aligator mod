class Weapon {
    constructor() {
        this.predictWeapon = 0;
        this.lastWeapon = 0;
    }

    getKeyCodeWeapon() {
        const {myPlayer} = playerManager;
        const keyNum = checkInput.lastWeaponButton || 1;
        if(myPlayer.weapons[keyNum - 1] !== undefined || keyNum == 1) {
            this.predictWeapon = myPlayer.weapons[keyNum - 1];
        } 
    }

    getGatherWeapon() {
        if(autogather.state) {
            if(combat.state) {
                this.predictWeapon = combat.weapon;
            } else if(autobreak.state) {
                this.predictWeapon = autobreak.weapon;
            }
        }
    }

    getFastestWeapon() {
        const {myPlayer} = playerManager;
        if(!settings.equipFastest) return;
        if(myPlayer.weapons[1] === 10 && ![7, 8].includes(myPlayer.weapons[0])) {
            this.predictWeapon = myPlayer.weapons[1];
        } else {
            this.predictWeapon = myPlayer.weapons[0];
        }
    }

    getReloadWeapon() {
        const {myPlayer} = playerManager;
        if(myPlayer.primaryReload < 1 && myPlayer.secondaryReload < 1) {
            if(myPlayer.weapons[0].speed < myPlayer.weapons[1].speed) {
                this.predictWeapon = myPlayer.weapons[0];
            } else {
                this.predictWeapon = myPlayer.weapons[1];
            }
        } else {
            if(myPlayer.primaryReload < 1) {
                this.predictWeapon = myPlayer.weapons[0];
            } else if(myPlayer.secondaryReload < 1) {
                this.predictWeapon = myPlayer.weapons[1];
            }
        }
    }

    send() {
        if (this.predictWeapon !== this.lastWeapon || place.reselectWeapon) {
            game.selectWeapon(this.predictWeapon);
            this.lastWeapon = this.predictWeapon;
        }
    }
}

class Combat {
    constructor() {
        this.angle = null;
        this.weapon = null;
        this.state = false;
        this.instaQueue = [];
        this.bull = 7;
        this.hat = 0;
    }

    update() {
        const {myPlayer} = playerManager;
        const {nearestEnemy} = playerManager;
        if(!nearestEnemy) return;
        
        // Check enemy collision
        nearestEnemy.collideSpike = this.checkCollision(nearestEnemy);

        // Handle enemy collision on spike combat
        if(nearestEnemy.collideSpike) {
            if(nearestEnemy.weapons[1] == 10) {
                if(nearestEnemy.secondaryReload == 1 && myPlayer.lastPrimaryReload == 1) { 
                    this.queueInsta("primary", nearestEnemy, this.bull);
                } else if(nearestEnemy.shameCount > 5) {
                    this.queueInsta("primary", nearestEnemy, this.bull);
                }
            }
        }
        
        // Process insta queue
        this.processInstaQueue();
    }

    queueInsta(type, instaEntity, hat) {
        const {myPlayer} = playerManager;
        const wpn = type === "primary" ? myPlayer.weapons[0] : myPlayer.weapons[1];
        
        this.instaQueue.push({
            weapon: wpn,
            instaEntity: instaEntity,
            hat: hat,
            angle: this.angleTo(instaEntity)
        });
    }

    processInstaQueue() {
        if(this.instaQueue.length === 0) {
            this.state = false; // Reset state when queue is empty
            return;
        }
        
        const insta = this.instaQueue[0];
        
        if(this.ready(insta.instaEntity, insta.weapon)) {
            // Execute insta
            this.angle = insta.angle;
            this.weapon = insta.weapon;
            this.state = true;
            this.hat = insta.hat;
            
            // Remove from queue
            this.instaQueue.shift();
        } else {
            // If not ready, remove stale item
            this.instaQueue.shift();
        }
    }

    angleTo(enemy) {
        if(!enemy) return false;
        const {myPlayer} = playerManager;
        return UTILS.getDirection(enemy.x2, enemy.y2, myPlayer.x2, myPlayer.y2);
    }

    checkCollision(enemy) {
        if (!enemy?.trap) return false;
        if (!enemy.damages || enemy.damages.length === 0) return false;
        
        const validDamages = [20, 30, 35, 45, 15, 22.5, 26.25, 33.75];
        
        // Check if any damage in the array matches
        return enemy.damages.some(dmgObj => {
            const enemyDamageRounded = Math.round(dmgObj.damage);
            return validDamages.some(damage => Math.round(damage) === enemyDamageRounded);
        });
    }

    ready(enemy, weapon) {
        const {myPlayer} = playerManager;

        if(weapon > 9) {
            if(myPlayer.secondaryReload < 1) {
                return false;
            }
        } else {
            if(myPlayer.primaryReload < 1) {
                return false;
            }
        }

        const dist = UTILS.getDistance(myPlayer.x, myPlayer.y, enemy.x, enemy.y);
        if(dist > 35 * 1.8 + items.weapons[weapon].range) {
            return false;
        }

        return true;
    }
}

class Dir {
    constructor() {
        this.lastDir = 0;
        this.predictDir = 0;
        this.serverDir = 0;
    }

    getMouseDir() {
        // Dont update dir if lock direction
        if (game.lockDir) return;

        // Mouse dir angle
        const mousePos = checkInput.getMousePosition();
        this.predictDir = UTILS.fixTo(Math.atan2(
            mousePos.y - window.innerHeight / 2,
            mousePos.x - window.innerWidth / 2) || 0, 2);
    }

    getGatherDir() {
        if(!autogather.state) return;
        if(combat.state) {
            this.predictDir = combat.angle;
        } else if (autobreak.state) {
            this.predictDir = autobreak.angle;
        }
    }

    getRenderDir() {
        // Run every frame for clean rendering
        this.getMouseDir();
    }

    send() {
        const myPlayer = playerManager.myPlayer;
        if (!myPlayer) return;
        // If current dir is same as last dir avoid wasting packets
        if (this.predictDir === this.lastDir) return;

        const isPrimary = weapon.predictWeapon < 9;
        const isReady = isPrimary ? myPlayer.primaryReload == 1 : myPlayer.secondaryReload == 1;
        if(!autogather.state || !isReady) return;

        this.lastDir = this.predictDir;

        this.serverDir = this.predictDir;
        game.sendDir(this.predictDir);
    }
}

class Autobreak {
    constructor() {
        this.state = false;
        this.angle = null;
        this.object = null;
        this.weapon = null;
    }

    inRange(weapon, object) {
        if(!weapon || !object) return false;
        const {myPlayer} = playerManager;
        const dist = UTILS.getDistance(myPlayer.x, myPlayer.y, object.x, object.y);
        if(dist > object.scale + items.weapons[weapon].range) return false;
        return true;
    }

    oneShot(weapon, object) {
        if(!weapon || !object) return false;
        const {myPlayer} = playerManager;
        let dmg = null;
        if(weapon >= 9) {
            dmg = myPlayer.secondarySDamage;
        } else {
            dmg = myPlayer.primarySDamage;
        }
        if(object.health <= dmg) {
            return true;
        }
        return false;
    }

    fastWeapon(weapon) {
        if(!weapon) return false;
        if(items.weapons[weapon].speed > 400) return false;
        return true;
    }

    distanceToEnemy(object) {
        const {nearestEnemy} = playerManager;
        if(!nearestEnemy || !object) return Infinity;
        return UTILS.getDistance(object.x, object.y, nearestEnemy.x, nearestEnemy.y);
    }

    selectTarget(spike, trap, weapon) {
        const {myPlayer} = playerManager;
        
        // Check which are in range
        const spikeInRange = spike ? this.inRange(weapon, spike) : false;
        const trapInRange = trap ? this.inRange(weapon, trap) : false;
        
        // If only one exists or only one is in range, pick that one
        if(!spike && trapInRange) return trap;
        if(!trap && spikeInRange) return spike;
        if(spikeInRange && !trapInRange) return spike;
        if(trapInRange && !spikeInRange) return trap;
        if(!spikeInRange && !trapInRange) return null;
        
        // Both in range - check oneshot status
        const spikeOneShot = this.oneShot(weapon, spike);
        const trapOneShot = this.oneShot(weapon, trap);
        
        // If one is oneshot and other isn't, kill the oneshot one
        if(spikeOneShot && !trapOneShot) return spike;
        if(trapOneShot && !spikeOneShot) return trap;
        
        // Both oneshot or both not oneshot - kill the one farther from enemy
        const spikeDistToEnemy = this.distanceToEnemy(spike);
        const trapDistToEnemy = this.distanceToEnemy(trap);
        
        return spikeDistToEnemy > trapDistToEnemy ? spike : trap;
    }

    update() {
        const {myPlayer} = playerManager;
        const {nearestEnemy} = playerManager;
        const primary = myPlayer.weapons[0];
        const secondary = myPlayer.weapons[1];
        this.state = false;

        const nearestTrap = objectManager.visibleObjects
            .filter(obj => 
                UTILS.getDistance(obj.x, obj.y, myPlayer.x, myPlayer.y) < 300 &&
                objectManager.isTrap(obj) && 
                objectManager.isEnemyObject(myPlayer, obj)
            )
            .reduce((nearest, obj) => {
                const dist = UTILS.getDistance(obj.x, obj.y, myPlayer.x, myPlayer.y);
                const nearestDist = nearest ? UTILS.getDistance(nearest.x, nearest.y, myPlayer.x, myPlayer.y) : Infinity;
                return dist < nearestDist ? obj : nearest;
        }, null);

        const nearestSpike = objectManager.visibleObjects
            .filter(obj => 
                UTILS.getDistance(obj.x, obj.y, myPlayer.x, myPlayer.y) < 300 &&
                objectManager.isSpike(obj) && 
                objectManager.isEnemyObject(myPlayer, obj)
            )
            .reduce((nearest, obj) => {
                const dist = UTILS.getDistance(obj.x, obj.y, myPlayer.x, myPlayer.y);
                const nearestDist = nearest ? UTILS.getDistance(nearest.x, nearest.y, myPlayer.x, myPlayer.y) : Infinity;
                return dist < nearestDist ? obj : nearest;
        }, null);

        // Check if primary is fast and can oneshot a target
        if(primary && this.fastWeapon(primary)) {
            const target = this.selectTarget(nearestSpike, nearestTrap, primary);
            if(target && this.oneShot(primary, target)) {
                // Primary can oneshot - use it
                this.state = true;
                this.object = target;
                this.weapon = primary;
                this.angle = UTILS.getDirection(target.x, target.y, myPlayer.x, myPlayer.y);
                return;
            }
        }
        
        // Otherwise, use secondary for everything else
        if(secondary && this.fastWeapon(secondary)) {
            const target = this.selectTarget(nearestSpike, nearestTrap, secondary);
            if(target) {
                this.state = true;
                this.object = target;
                this.weapon = secondary;
                this.angle = UTILS.getDirection(target.x, target.y, myPlayer.x, myPlayer.y);
                return;
            }
        }
    }
}

