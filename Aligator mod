    setupSkinList(container) {
        this.intervals.skinCheck = setInterval(() => {
            const originalHolder = this.elements.skinColorHolder;
            if (!originalHolder || originalHolder.children.length === 0) {
                container.innerHTML = `<div class="loader-text">Loading Assets...</div>`;
                return;
            }

            clearInterval(this.intervals.skinCheck);
            container.innerHTML = "";
            originalHolder.style.display = "none";

            const skins = Array.from(originalHolder.children);

            skins.forEach((skinEl, index) => {
                const row = document.createElement("div");
                row.className = "list-row skin-row";

                const colorVal = skinEl.style.backgroundColor || getComputedStyle(skinEl).backgroundColor;

                const colorPreview = document.createElement("div");
                colorPreview.className = "skin-preview";
                colorPreview.style.backgroundColor = colorVal;
                colorPreview.style.boxShadow = `0 0 8px ${colorVal}`;

                const nameSpan = document.createElement("span");
                nameSpan.innerText = `Skin ${index + 1}`;
                nameSpan.className = "row-text";

                row.appendChild(colorPreview);
                row.appendChild(nameSpan);

                row.onclick = () => {
                    skinEl.click();
                    Array.from(container.children).forEach(c => c.classList.remove('selected'));
                    row.classList.add('selected');
                };

                container.appendChild(row);
            });
        }, 200);
    }

    async setupServerList(container) {
        container.innerHTML = `<div class="loader-text">Scanning Network...</div>`;
        this.servers = await this.getServers();
        this.updateServerList(container);

        this.intervals.serverUpdate = setInterval(async () => {
            this.servers = await this.getServers();
            this.updateServerList(container);
