class DistribuitionDamages {
    constructor(){
        this.damages = [];
        this.distributedDamages = [];
        this.lastDamageTick = 0;
        this.damagesAfterDeath = [];
    }

    getDamages() {
        const {myPlayer} = playerManager;
        this.distributedDamages = [];
        this.damages = [];
        if(myPlayer.damages.length > 0) {
            this.lastDamageTick = tickManager.count;
            this.damages = [...myPlayer.damages];
            if(!myPlayer.alive) {
                this.damagesAfterDeath = this.damages;
            }
        }
    }

   update(object) {
        const {myPlayer} = playerManager;
        
        if(object.type == "hit") {
            if(this.damages.length == 0) return;
            const {weapon, player} = object;

            let damage = items.weapons[weapon].dmg * config.weaponVariants[player.weaponVariants[weapon]].val;
            damage *= (shop.getHat(player.skinIndex).dmgMultO || 1);
            damage *= (shop.getAcc(player.tailIndex).dmgMultO || 1);
            damage *= (shop.getHat(myPlayer.skinIndex).dmgMult || 1);
            
            for(let i = this.damages.length - 1; i >= 0; i--){
                if(this.damagesMatch(this.damages[i].damage, damage)){ 
                    this.distributedDamages.push({
                        type: "hit", 
                        damage: damage, 
                        player: player, 
                        weapon: weapon
                    });
                    this.damages.splice(i, 1);
                    break;
                }
            }
        } else if(object.type == "shoot") {
            if(this.damages.length == 0) return;
            const {projectile} = object;
            let damage = projectile.dmg * (shop.getHat(myPlayer.skinIndex).dmgMult || 1);
            
            for(let i = this.damages.length - 1; i >= 0; i--){
                if(this.damagesMatch(this.damages[i].damage, damage)){
                    this.distributedDamages.push({
                        type: "shoot", 
                        damage: damage, 
                        projectile: projectile
                    });
                    this.damages.splice(i, 1);
                    break;
                }
            } 
        } else if(object.type == "spikes"){
            if(this.damages.length == 0) return;
            const smallSpikesDamage = 20 * (shop.getHat(myPlayer.skinIndex).dmgMult || 1);
            const greaterSpikesDamage = 35 * (shop.getHat(myPlayer.skinIndex).dmgMult || 1);
            const poisonSpikesDamage = 30 * (shop.getHat(myPlayer.skinIndex).dmgMult || 1);
            const spinningSpikesDamage = 45 * (shop.getHat(myPlayer.skinIndex).dmgMult || 1);

            const spikeDamages = [smallSpikesDamage, greaterSpikesDamage, poisonSpikesDamage, spinningSpikesDamage];
            const spikeDamageTypes = ["small", "greater", "poison", "spinning"]; // matching order

            for(let i = this.damages.length - 1; i >= 0; i--){
                const receivedDamage = this.damages[i].damage;
                
                for(let j = 0; j < spikeDamages.length; j++){
                        if(this.damagesMatch(receivedDamage, spikeDamages[j])){
                            this.distributedDamages.push({
                                type: "spikes", 
                                damage: receivedDamage,
                                spikeType: spikeDamageTypes[j]
                            });
                            this.damages.splice(i, 1);
                            break;
                        }
                }
            }
        } else if(object.type == "poison"){
            if(this.damages.length == 0) return;
            const poisonDamage = 5 * (shop.getHat(myPlayer.skinIndex).dmgMult || 1);
            const bullDamage = 5;

            const poisonDamages = [poisonDamage, bullDamage];

            for(let i = this.damages.length - 1; i >= 0; i--){
                const receivedDamage = this.damages[i].damage;
                
                // Check if this damage matches poison or bull
                for(const poisonDmg of poisonDamages){
                    if(this.damagesMatch(receivedDamage, poisonDmg)){
                        this.distributedDamages.push({
                            type: "poison", 
                            damage: receivedDamage,
                            time: this.damages[i].time
                        });
                        this.damages.splice(i, 1);
                        break; // Move to next damage after match
                    }
                }
            }
        } else if(object.type == "enemyhats"){
            const {weapon} = object;
            const myPlayer = playerManager.myPlayer;
            // Base weapon damage you're dealing
            let baseDamage = items.weapons[weapon].dmg * (shop.getHat(myPlayer.skinIndex).dmgMultO || 1) * config.weaponVariants[myPlayer.weaponVariants[weapon]].val;
            // Calculate hat damages based on YOUR weapon damage
            const hatDamages = [];
            
            for(let enemy of playerManager.enemiesNear) {
                let damage = baseDamage;

                // Calculate反伤 damage from enemy's offensive hats
                const sawbladeDamage = damage * .15;
                const cxWingsDamage = damage * .25;
                const spikeHatDamage = damage * .45;
                
                // Add to possible hat damages if enemy has these hats
                if(enemy.tailIndex == 16) { // Sawblade hat ID
                    hatDamages.push(sawbladeDamage);
                }
                if(enemy.tailIndex == 21) { // CX Wings hat ID
                    hatDamages.push(cxWingsDamage);
                }
                if(enemy.skinIndex == 11) { // Spike hat ID (adjust if different)
                    hatDamages.push(spikeHatDamage);
                }
            }

            // Match received damage against calculated hat damages
            for(let i = this.damages.length - 1; i >= 0; i--){
                const receivedDamage = this.damages[i].damage;
                // Check if this damage matches any hat type
                for(const hatDamage of hatDamages){
                    if(this.damagesMatch(receivedDamage, hatDamage)){
                        this.distributedDamages.push({
                            type: "enemyhats", 
                            damage: receivedDamage,
                            weapon: weapon
                        });
                        this.damages.splice(i, 1);
                        break; // Move to next damage after match
                    }
                }
            }
        }
    }

    damagesMatch(damage1, damage2, threshold = 0.3) {
        return Math.abs(damage1 - damage2) < threshold;
    }

}

