    updateServerList(container) {
        if (this.servers.length === 0) {
            container.innerHTML = `<div class="loader-text">No Signals Detected</div>`;
            return;
        }

        const sortedServers = [...this.servers].sort((a, b) => {
            if (a.ping === b.ping) return b.playerCount - a.playerCount;
            return a.ping - b.ping;
        });

        const prevScroll = container.scrollTop;
        container.innerHTML = "";

        sortedServers.forEach(server => {
            const serverBox = document.createElement("div");
            serverBox.className = "list-row server-row";

            const countColor = server.playerCount >= 40 ? "#ff4d4d" : server.playerCount >= 20 ? "#ffcc00" : "#00e676";
