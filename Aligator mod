    static mainContext = document.getElementById("gameCanvas")?.getContext("2d");

    constructor() {
        this.time = { now: 0, delta: 0, last: performance.now() };
        this.camera = { x: config.mapScale / 2 + config.riverWidth, y: config.mapScale / 2 };
        this.waterMult = this.waterPlus = 1;
        this.outlineColor = "#525252";
        this.darkOutlineColor = "#3d3f42";
        this.outlineWidth = 5.5;
        this.sprites = {
            tool: {}, gameObject: {}, item: [], access: {}, accessPointers: {},
            skin: {}, skinPointers: {}, projectile: {}, ai: {}
        };
        this.textManager = new TextManager();
    }

    get ctx() { return GameVisualsManager.mainContext; }
    get myPlayer() { return playerManager.myPlayer; }
    get players() { return playerManager.players; }
    get ais() { return aiManager.ais; }
    get offset() {
        return {
            x: this.camera.x - config.maxScreenWidth / 2,
            y: this.camera.y - config.maxScreenHeight / 2
        };
    }

    // ============================================================================
    // CORE LOOP
    // ============================================================================

    start() {
        for (let i = 0; i < 10; i++) cancelAnimationFrame(i);
        if (!this.zoom && GameVisualsManager.gameCanvas) {
            this.zoom = new Zoom(this, {
                zoomSpeed: 0.1,
                minFactor: 0.5,
                maxFactor: 2.0
            });
            this.zoom.initialize(GameVisualsManager.gameCanvas, GameVisualsManager.mainContext);
        }
        const loop = () => {
            this.updateTime();
            this.update();
            requestAnimationFrame(loop);
        };
        loop();
    }

    updateTime() {
        this.time.now = performance.now();
        this.time.delta = this.time.now - this.time.last;
        this.time.last = this.time.now;
    }

    update() {
        this.updateCamera();
        this.interpolateEntities();
        this.renderBackground();
        this.renderGrid();
        this.renderMinimap();
        this.renderWater();
        this.renderVelocityPosition();
        [-1, 0, 1, 2, 3].forEach(layer => {
            if (layer === 0) {
                this.renderProjectiles(0);
                this.renderPlayers(0);
                this.renderAIs();
            }
            this.renderGameObjects(layer);
            if (layer === 1) {
                this.renderProjectiles(1);
                this.renderPlayers(1);
            }
        });
        // this.renderPrePlaceObjects();
        this.renderPlaceObjects();
        this.renderMapBoundaries();
        this.renderObjectHealth();
        this.renderDayNight();
        this.renderPlayerUI();
        this.renderChatMessages();
        this.textManager.update(this.time.delta, this.ctx, this.offset.x, this.offset.y);
    }

    // ============================================================================
    // CAMERA & INTERPOLATION
    // ============================================================================

    updateCamera() {
        const target = this.myPlayer
        ? { x: this.myPlayer.xRender, y: this.myPlayer.yRender }
        : { x: config.mapScale / 2 + config.riverWidth, y: config.mapScale / 2 };

        const dist = UTILS.getDistance(this.camera.x, this.camera.y, target.x, target.y);
        if (dist > 0.5) {
            const dir = UTILS.getDirection(target.x, target.y, this.camera.x, this.camera.y);
            const speed = Math.min(dist * 0.01 * this.time.delta, dist);
            this.camera.x += speed * Math.cos(dir);
            this.camera.y += speed * Math.sin(dir);
        } else {
            this.camera.x = target.x;
            this.camera.y = target.y;
        }
    }

    interpolateEntities() {
        const now = this.time.now;
        const lastTime = now - (1000 / config.serverUpdateRate);

        [...this.players, ...this.ais].forEach(e => {
            if (!e.visible || e.x === undefined) return;

            if (e.forcePos) {
                e.xRender = e.x;
                e.yRender = e.y;
                e.dirRender = e.dir;
                return;
            }

            e.updateTime += this.time.delta;
            const progress = Math.min(1.7, e.updateTime / 170);

            e.xRender = e.lastXRender + (e.x - e.lastXRender) * progress;
            e.yRender = e.lastYRender + (e.y - e.lastYRender) * progress;

            const total = e.time - e.lastTime;
            const fraction = lastTime - e.lastTime;
            const ratio = (fraction / total);

            e.dirRender = UTILS.lerpAngle(e.dir, e.lastDir, Math.min(1.2, ratio));
        });
    }

    // ============================================================================
    // MINIMAP
    // ============================================================================

    renderMinimap(delta) {
        if (!this.myPlayer?.alive) return;

        const mapDisplay = document.getElementById("mapDisplay");
        if (!mapDisplay) return;

        const mapContext = mapDisplay.getContext("2d");
        if (!mapContext) return;

        const w = mapDisplay.width;
        const h = mapDisplay.height;
        const scale = config.mapScale;

        mapContext.clearRect(0, 0, w, h);

        // RENDER MYPLAYER
        mapContext.globalAlpha = 1;
        mapContext.fillStyle = "#fff";
        this.renderCircle(
            (this.myPlayer.x / scale) * w,
            (this.myPlayer.y / scale) * h,
            7, mapContext, true
        );

        mapContext.fillStyle = "rgba(255,255,255,0.35)"

        // RENDER TEAMMATES:
        if (this.myPlayer.team && playerManager.minimapData && playerManager.minimapData.length > 0) {
            mapContext.fillStyle = "rgba(255,255,255,0.35)";

            for (let i = 0; i < playerManager.minimapData.length; i++) {
                const teammate = playerManager.minimapData[i];
                if (teammate && teammate.length >= 2) {
                    const teammateX = (teammate[0] / scale) * w;
                    const teammateY = (teammate[1] / scale) * h;
                    this.renderCircle(teammateX, teammateY, 7, mapContext, true);
                }
            }
        }

        // DEATH LOCATION:
        if (playerManager.lastDeath) {
            mapContext.fillStyle = "#fc5553";
            mapContext.font = "34px Hammersmith One";
            mapContext.textBaseline = "middle";
            mapContext.textAlign = "center";
            mapContext.fillText("x",
                                (playerManager.lastDeath.x / scale) * w,
                                (playerManager.lastDeath.y / scale) * h
                               );
        }

        // MAP MARKER:
        /*
        if (typeof mapMarker !== 'undefined' && mapMarker) {
            mapContext.fillStyle = "#fff";
            mapContext.font = "34px Hammersmith One";
            mapContext.textBaseline = "middle";
            mapContext.textAlign = "center";
            mapContext.fillText("x",
                (mapMarker.x / scale) * w,
                (mapMarker.y / scale) * h
            );
        }
        */
    }

    // ============================================================================
    // SHOW TEXT
    // ============================================================================

    showText(data) {
        this.textManager.showText(
            data[0],
            data[1],
            50,
            0.18,
            500,
            Math.abs(data[2]),
            (data[2] >= 0) ? "#fff" : "#8ecc51"
        );
    }

    renderChatMessages() {
        this.ctx.font = "32px Hammersmith One";
        this.ctx.textBaseline = "middle";
        this.ctx.textAlign = "center";

        for (let i = 0; i < this.players.length; i++) {
            const tmpObj = this.players[i];

            if (tmpObj.visible && tmpObj.chatCountdown > 0) {
                tmpObj.chatCountdown -= this.time.delta;
                if (tmpObj.chatCountdown <= 0) {
                    tmpObj.chatCountdown = 0;
                }

                const tmpSize = this.ctx.measureText(tmpObj.chatMessage);
                const tmpX = tmpObj.xRender - this.offset.x;
                const tmpY = tmpObj.yRender - tmpObj.scale - this.offset.y - 90;
                const tmpH = 47;
                const tmpW = tmpSize.width + 17;

                this.ctx.fillStyle = "rgba(0,0,0,0.2)";
                this.ctx.roundRect(tmpX - tmpW / 2, tmpY - tmpH / 2, tmpW, tmpH, 6);
                this.ctx.fill();
                this.ctx.fillStyle = "#fff";
                this.ctx.fillText(tmpObj.chatMessage, tmpX, tmpY);
            }
        }
    }

    // ============================================================================
    // ENVIRONMENT
    // ============================================================================

    renderBackground() {
        const { y: yOffset } = this.offset;
        const snowTop = config.snowBiomeTop - yOffset;
        const desertTop = config.mapScale - config.snowBiomeTop - yOffset;
        const h = config.maxScreenHeight;
        const w = config.maxScreenWidth;

        this.ctx.globalAlpha = 1;

        if (snowTop <= 0 && desertTop >= h) this.fillScreen("#b6db66");
        else if (desertTop <= 0) this.fillScreen("#dbc666");
        else if (snowTop >= h) this.fillScreen("#fff");
        else if (snowTop >= 0) {
            this.ctx.fillStyle = "#fff";
            this.ctx.fillRect(0, 0, w, snowTop);
            this.ctx.fillStyle = "#b6db66";
            this.ctx.fillRect(0, snowTop, w, h - snowTop);
        } else {
            this.ctx.fillStyle = "#b6db66";
            this.ctx.fillRect(0, 0, w, desertTop);
            this.ctx.fillStyle = "#dbc666";
            this.ctx.fillRect(0, desertTop, w, h - desertTop);
        }
    }

    renderGrid() {
        if(!settings.renderGrid) return;

        const { x: camX, y: camY } = this.offset;
        const gridSize = config.maxScreenHeight / 18;
        const w = config.maxScreenWidth;
        const h = config.maxScreenHeight;

        this.ctx.lineWidth = 4;
        this.ctx.strokeStyle = "#000";
        this.ctx.globalAlpha = 0.06;
        this.ctx.beginPath();

        // Vertical lines
        for (let x = -camX % gridSize; x < w; x += gridSize) {
            if (x > 0) {
                this.ctx.moveTo(x, 0);
                this.ctx.lineTo(x, h);
            }
        }

        // Horizontal lines
        for (let y = -camY % gridSize; y < h; y += gridSize) {
            if (y > 0) {
                this.ctx.moveTo(0, y);
                this.ctx.lineTo(w, y);
            }
        }

        this.ctx.stroke();
        this.ctx.globalAlpha = 1;
    }

    renderWater() {
        const { x: xOffset, y: yOffset } = this.offset;

        this.waterMult += this.waterPlus * config.waveSpeed * this.time.delta;
        if (this.waterMult >= config.waveMax) {
            this.waterMult = config.waveMax;
            this.waterPlus = -1;
        } else if (this.waterMult <= 1) {
            this.waterMult = this.waterPlus = 1;
        }

        this.ctx.globalAlpha = 1;
        this.ctx.fillStyle = "#dbc666";
        this.renderWaterBody(xOffset, yOffset, config.riverPadding);
        this.ctx.fillStyle = "#91b2db";
        this.renderWaterBody(xOffset, yOffset, (this.waterMult - 1) * 250);
    }

    renderWaterBody(xOffset, yOffset, padding) {
        const w = config.riverWidth + padding;
        const y = config.mapScale / 2 - yOffset - w / 2;
        if (y < config.maxScreenHeight && y + w > 0) {
            this.ctx.fillRect(0, y, config.maxScreenWidth, w);
        }
    }

    renderMapBoundaries() {
        const { x: xOffset, y: yOffset } = this.offset;
        const w = config.maxScreenWidth;
        const h = config.maxScreenHeight;
        const m = config.mapScale;

        this.ctx.fillStyle = "#000";
        this.ctx.globalAlpha = 0.09;

        if (xOffset <= 0) this.ctx.fillRect(0, 0, -xOffset, h);
        if (m - xOffset <= w) {
            const tmpY = Math.max(0, -yOffset);
            this.ctx.fillRect(m - xOffset, tmpY, w - (m - xOffset), h - tmpY);
        }
        if (yOffset <= 0) this.ctx.fillRect(-xOffset, 0, w + xOffset, -yOffset);
        if (m - yOffset <= h) {
            const tmpX = Math.max(0, -xOffset);
            const tmpMin = m - xOffset <= w ? w - (m - xOffset) : 0;
            this.ctx.fillRect(tmpX, m - yOffset, w - tmpX - tmpMin, h - (m - yOffset));
        }

        this.ctx.globalAlpha = 1;
    }

    renderDayNight() {
        this.ctx.globalAlpha = 1;
        this.ctx.fillStyle = "rgba(0, 0, 50, 0.50)";
        this.ctx.fillRect(0, 0, config.maxScreenWidth, config.maxScreenHeight);
    }

    // ============================================================================
    // GAME OBJECTS
    // ============================================================================

    renderGameObjects(layer) {
        const { x: xOffset, y: yOffset } = this.offset;
        this.ctx.globalAlpha = 1;
        this.ctx.strokeStyle = this.outlineColor;

        objectManager.objects.forEach(obj => {
            if (!obj.active) return;

            const x = obj.x + obj.xWiggle - xOffset;
            const y = obj.y + obj.yWiggle - yOffset;

            if (layer === 0) obj.update(this.time.delta);

            if (obj.layer === layer && this.isOnScreen(x, y, obj.scale + (obj.blocker || 0))) {
                this.ctx.globalAlpha = obj.hideFromEnemy ? 0.6 : 1;
                if (obj.isItem) this.renderItemObject(obj, x, y);
                else {
                    const sprite = this.getResSprite(obj);
                    this.ctx.drawImage(sprite, x - sprite.width / 2, y - sprite.height / 2);
                }
            }
        });
    }

   

    renderItemObject(obj, x, y) {
        const sprite = this.getItemSprite(obj);
        this.ctx.save();
        this.ctx.translate(x, y);
        this.ctx.rotate(obj.dir);
        this.ctx.drawImage(sprite, -sprite.width / 2, -sprite.height / 2);

        if (obj.blocker) {
            this.ctx.strokeStyle = "#db6e6e";
            this.ctx.globalAlpha = 0.3;
            this.ctx.lineWidth = 6;
            this.renderCircle(0, 0, obj.blocker, this.ctx, false, true);
        }

        this.ctx.restore();
    }

    renderObjectHealth() { // VISIBLE OBJECTS LATER
        const { x: xOffset, y: yOffset } = this.offset;
        if (!objectManager.visibleObjects || !this.myPlayer) return; // render reload for everryone or just myplayer?

        Object.values(objectManager.visibleObjects).forEach(obj => {
            const dist = UTILS.getDistance(this.myPlayer.x, this.myPlayer.y, obj.x, obj.y);
            if (dist < 300 && obj.isItem) {
                const r = obj.id > 5 && obj.id < 10 ? 30 : 20;
                const angle = obj.health * (Math.PI * 2 / obj.maxHealth);
                const x = obj.x - xOffset;
                const y = obj.y - yOffset;

                this.ctx.globalAlpha = 1;
                this.ctx.lineCap = "round";

                this.ctx.strokeStyle = this.darkOutlineColor;
                this.ctx.lineWidth = 12.5;
                this.ctx.beginPath();
                this.ctx.arc(x, y, r, 0, angle);
                this.ctx.stroke();

                const isOwn = obj.owner.sid === this.myPlayer.sid;
                const isAlly = this.myPlayer.isAlly(obj.owner.sid);
                this.ctx.strokeStyle = isOwn ? "#8ecc51" : (isAlly ? "#518ecc" : "#cc5151");
                this.ctx.lineWidth = 5;
                this.ctx.beginPath();
                this.ctx.arc(x, y, r, 0, angle);
                this.ctx.stroke();
            }
        });
    }

    // ============================================================================
    // PROJECTILES
    // ============================================================================

    renderProjectiles(layer) {
        const { x: xOffset, y: yOffset } = this.offset;
        this.ctx.globalAlpha = 1;
        this.ctx.lineWidth = this.outlineWidth;

        projectileManager.projectiles.forEach(obj => {
            if (!obj.active || obj.layer !== layer) return;
            obj.animate(this.time.delta);

            if (obj.active && this.isOnScreen(obj.xRender - xOffset, obj.yRender - yOffset, obj.scale)) {
                this.ctx.save();
                this.ctx.translate(obj.xRender - xOffset, obj.yRender - yOffset);
                this.ctx.rotate(obj.dir);
                this.renderProjectile(0, 0, obj, this.ctx, 1);
                this.ctx.restore();
            }
        });
    }

    // ============================================================================
    // ENTITIES
    // ============================================================================

    renderPlayers(zIndex) {
        const { x: xOffset, y: yOffset } = this.offset;
        this.ctx.globalAlpha = 1;
        

        this.players.forEach(p => {
            if (p.zIndex !== zIndex) return;
            p.animate(this.time.delta);

            if (p.visible) {
                dir.getRenderDir();
                p.skinRot += 0.002 * this.time.delta;
                let d = null;
                if(p === this.myPlayer) {
                    if(settings.renderRealDir) {
                        d = dir.serverDir + p.dirPlus;
                    } else {
                        d = dir.predictDir + p.dirPlus;
                    }
                } else {
                    d = p.dirRender + p.dirPlus;
                }
              
                this.ctx.save();
                this.ctx.translate(p.xRender - xOffset, p.yRender - yOffset);
                this.ctx.rotate(d);
                this.renderPlayer(p, this.ctx);
                this.ctx.restore();
            }
        });
    }

    renderPrePlaceObjects() {
        if (!this.myPlayer) return;
        const { x: xOffset, y: yOffset } = this.offset;
        
        placer.preplaceObjects.forEach((object, index) => {
            const screenX = object.x - xOffset;
            const screenY = object.y - yOffset;
            
            // Pulsing glow effect
            const pulse = Math.sin(Date.now() / 200 + index) * 0.3 + 0.7;
            
            // Outer glow circle
            this.ctx.globalAlpha = 0.3 * pulse;
            this.ctx.fillStyle = '#ff4444';
            this.ctx.beginPath();
            this.ctx.arc(screenX, screenY, object.scale + 15, 0, Math.PI * 2);
            this.ctx.fill();
            
            // Inner highlight circle
            this.ctx.globalAlpha = 0.6 * pulse;
            this.ctx.strokeStyle = '#ff6666';
            this.ctx.lineWidth = 3;
            this.ctx.beginPath();
            this.ctx.arc(screenX, screenY, object.scale + 8, 0, Math.PI * 2);
            this.ctx.stroke();
            
            // Target crosshair
            this.ctx.globalAlpha = 0.8;
            this.ctx.strokeStyle = '#ffffff';
            this.ctx.lineWidth = 2;
            const crossSize = 10;
            
            // Horizontal line
            this.ctx.beginPath();
            this.ctx.moveTo(screenX - crossSize, screenY);
            this.ctx.lineTo(screenX + crossSize, screenY);
            this.ctx.stroke();
            
            // Vertical line
            this.ctx.beginPath();
            this.ctx.moveTo(screenX, screenY - crossSize);
            this.ctx.lineTo(screenX, screenY + crossSize);
            this.ctx.stroke();
            
            this.ctx.globalAlpha = 1;
        });
    }

renderPlaceObjects() {
    if(!this.myPlayer) return;
    if(!placer.placeAngles || placer.placeAngles.length === 0) return;
    
    const { x: xOffset, y: yOffset } = this.offset;
    
    for(let i = 0; i < placer.placeAngles.length; i++) {
        const place = placer.placeAngles[i];
        
        const objX = place.x - xOffset;
        const objY = place.y - yOffset;
        
        const tempObj = {
            id: place.id,
            scale: place.scale,
            name: items.list[place.id].name,
        };
        
        const sprite = this.getItemSprite(tempObj, false);
        if(sprite) {
            const isAutoPlace = !place.preplace;
            const isReady = !place.preplace || (place.preplaceObject && place.preplaceObject.readyToPreplace);
            
            // Sharper pulse for ready state
            const pulse = isReady ? (Math.sin(Date.now() / 200) * 0.5 + 0.5) : 0.3;
            
            if(isAutoPlace) {
                // Autoplace: just render with shadowy contrast (darker/desaturated)
                const tempCanvas = document.createElement('canvas');
                tempCanvas.width = sprite.width;
                tempCanvas.height = sprite.height;
                const tempCtx = tempCanvas.getContext('2d');
                
                tempCtx.drawImage(sprite, 0, 0);
                
                // Add dark overlay for shadowy effect
                tempCtx.globalCompositeOperation = 'source-atop';
                tempCtx.globalAlpha = 0.1;
                tempCtx.fillStyle = '#000000';
                tempCtx.fillRect(0, 0, sprite.width, sprite.height);
                
                this.ctx.globalAlpha = 0.7 + pulse * 0.2;
                this.ctx.drawImage(tempCanvas, objX - sprite.width / 2, objY - sprite.height / 2);
                this.ctx.globalAlpha = 1;
            } else {
                // Preplace: red colored
                const tempCanvas = document.createElement('canvas');
                tempCanvas.width = sprite.width;
                tempCanvas.height = sprite.height;
                const tempCtx = tempCanvas.getContext('2d');
                
                tempCtx.drawImage(sprite, 0, 0);
                
                tempCtx.globalCompositeOperation = 'source-atop';
                tempCtx.globalAlpha = isReady ? 0.7 : 0.5;
                tempCtx.fillStyle = isReady ? '#ff3333' : '#ff6666';
                tempCtx.fillRect(0, 0, sprite.width, sprite.height);
                
                this.ctx.globalAlpha = isReady ? (0.85 + pulse * 0.15) : 0.5;
                this.ctx.drawImage(tempCanvas, objX - sprite.width / 2, objY - sprite.height / 2);
                this.ctx.globalAlpha = 1;
            }
        }
    }
}

    renderVelocityPosition() {
        if (!this.myPlayer) return;
        if(!settings.renderVel) return;
        const { x: xOffset, y: yOffset } = this.offset;

        this.ctx.globalAlpha = 0.5;

            const obj = this.myPlayer;

            this.ctx.save();
            this.ctx.translate(obj.x2 - xOffset, obj.y2 - yOffset);

            let d = null;
            if (obj === this.myPlayer) {
                d = (settings.renderRealDir ? dir.serverDir : dir.predictDir) + obj.dirPlus;
            } else {
                d = obj.dir + obj.dirPlus;
            }

            this.ctx.rotate(d);
            this.renderPlayer(obj, this.ctx);
            this.ctx.restore();

        this.ctx.globalAlpha = 1;
    }


    renderPlayer(obj, ctxt = this.ctx) {
        ctxt.lineWidth = this.outlineWidth;
        ctxt.lineJoin = "miter";

        const weapon = items.weapons[obj.weaponIndex];
        const handAngle = (Math.PI / 4) * (weapon.armS || 1);
        const oHandAngle = obj.buildIndex < 0 ? (weapon.hndS || 1) : 1;
        const oHandDist = obj.buildIndex < 0 ? (weapon.hndD || 1) : 1;

        if (obj.tailIndex > 0) this.renderTail(obj.tailIndex, ctxt, obj);

        if (obj.buildIndex < 0 && !weapon.aboveHand) {
            this.renderTool(weapon, config.weaponVariants[obj.weaponVariant].src, obj.scale, 0, ctxt);
            if (weapon.projectile !== undefined && !weapon.hideProjectile) {
                this.renderProjectile(obj.scale, 0, items.projectiles[weapon.projectile], this.ctx);
            }
        }

        ctxt.fillStyle = config.skinColors[obj.skinColor];
        this.renderCircle(obj.scale * Math.cos(handAngle), obj.scale * Math.sin(handAngle), 14);
        this.renderCircle(
            (obj.scale * oHandDist) * Math.cos(-handAngle * oHandAngle),
            (obj.scale * oHandDist) * Math.sin(-handAngle * oHandAngle),
            14
        );

        if (obj.buildIndex < 0 && weapon.aboveHand) {
            this.renderTool(weapon, config.weaponVariants[obj.weaponVariant].src, obj.scale, 0, ctxt);
            if (weapon.projectile !== undefined && !weapon.hideProjectile) {
                this.renderProjectile(obj.scale, 0, items.projectiles[weapon.projectile], this.ctx);
            }
        }

        if (obj.buildIndex >= 0) {
            const sprite = this.getItemSprite(items.list[obj.buildIndex]);
            ctxt.drawImage(sprite, obj.scale - items.list[obj.buildIndex].holdOffset, -sprite.width / 2);
        }

        this.renderCircle(0, 0, obj.scale, ctxt);

        if (obj.skinIndex > 0) {
            ctxt.rotate(Math.PI / 2);
            this.renderSkin(obj.skinIndex, ctxt, null, obj);
        }
    }

    renderAIs() {
        const { x: xOffset, y: yOffset } = this.offset;
        this.ctx.globalAlpha = 1;

        this.ais.forEach(ai => {
            if (!ai.active || !ai.visible) return;

            ai.animate(this.time.delta);
            this.ctx.save();
            this.ctx.translate(ai.xRender - xOffset, ai.yRender - yOffset);
            this.ctx.rotate(ai.dirRender + ai.dirPlus - Math.PI / 2);
            this.renderAI(ai, this.ctx);
            this.ctx.restore();
        });
    }

    renderAI(obj, ctxt) {
        let sprite = this.sprites.ai[obj.index];
        if (!sprite) {
            sprite = new Image();
            sprite.onload = function() { this.isLoaded = true; this.onload = null; };
            sprite.src = `.././img/animals/${obj.src}.png`;
            this.sprites.ai[obj.index] = sprite;
        }
        if (sprite.isLoaded) {
            const scale = obj.scale * 1.2 * (obj.spriteMlt || 1);
            ctxt.drawImage(sprite, -scale, -scale, scale * 2, scale * 2);
        }
    }

    renderPlayerUI() {
        const { x: xOffset, y: yOffset } = this.offset;
        this.ctx.strokeStyle = this.darkOutlineColor;

        [...this.players, ...this.ais].forEach(e => {
            if (!e.visible) return;
            const showUI = e.skinIndex !== 10 || e === this.myPlayer ||
                  (e.team && e.team === this.myPlayer?.team);
            if (showUI) {
                this.renderEntityHealth(e, xOffset, yOffset);
                this.renderEntityReload(e, xOffset, yOffset);
                this.renderEntityShame(e, xOffset, yOffset);
                this.renderPlayerPredictedDamage(e, xOffset, yOffset);
                this.renderEntityName(e, xOffset, yOffset);
            }
        });
    }

    renderPlayerPredictedDamage(e, xOffset, yOffset) {
    if(e != this.myPlayer) return;
    if(!this.myPlayer) return;
    const dmg = damage.predictTotal;
    const text = `⟨${Math.round(dmg)}⟩`;

    this.ctx.textBaseline = "middle";
    this.ctx.textAlign = "center";
    this.ctx.lineWidth = 6;
    this.ctx.lineJoin = "round";
    this.ctx.strokeStyle = "#000";
    this.ctx.font = "30px Hammersmith One";

    const nameText = `${e.team ? `[${e.team}] ` : ``}${e.name || ``}`;
    const nameWidth = this.ctx.measureText(nameText).width;
    const damageWidth = this.ctx.measureText(text).width;

    const x = e.xRender - xOffset + (nameWidth / 2) + (damageWidth / 2);
    const y = e.yRender - yOffset - e.scale - config.nameY;

    this.ctx.strokeText(text, x, y);
    this.ctx.fillStyle = "#ffffff";
    this.ctx.fillText(text, x, y);
}

renderEntityShame(e, xOffset, yOffset) {
    if(!e.isPlayer) return;
    if(e.shameCount <= 0 && e.shameTimer <= 0) return;

    const x = e.xRender - xOffset;
    const y = e.yRender - yOffset + e.scale + config.nameY + 19;
    const w = config.healthBarWidth;
    const p = config.healthBarPad;
    const barHeight = 10;
    const angle = 4;
    const maxShame = 7;
    const isTimer = e.shameTimer > 0;

    const fillRatio = isTimer
        ? (e.shameTimer / 30000)
        : (e.shameCount / maxShame);

    const label = isTimer
        ? `${Math.ceil(e.shameTimer / 1000)}s / 30s`
        : `${e.shameCount} / ${maxShame}`;

    // Background - same style as health bar
    this.ctx.fillStyle = this.darkOutlineColor;
    this.ctx.beginPath();
    this.ctx.moveTo(x - w - p + angle, y);
    this.ctx.lineTo(x + w + p - angle, y);
    this.ctx.lineTo(x + w + p, y + barHeight / 2);
    this.ctx.lineTo(x + w + p - angle, y + barHeight);
    this.ctx.lineTo(x - w - p + angle, y + barHeight);
    this.ctx.lineTo(x - w - p, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();

    // Draw segments
    const totalWidth = w * 2;
    const segmentWidth = totalWidth / maxShame;
    const segmentGap = 3;

    for(let i = 0; i < maxShame; i++) {
        const sx = x - w + segmentWidth * i;
        const segW = segmentWidth - segmentGap;
        const filled = isTimer
            ? (i / maxShame) < fillRatio
            : i < e.shameCount;

        // Segment background (unfilled)
        this.ctx.fillStyle = "rgba(40, 35, 30, 0.7)";
        this.ctx.beginPath();
        this.ctx.moveTo(sx + 2, y + p);
        this.ctx.lineTo(sx + segW, y + p);
        this.ctx.lineTo(sx + segW, y + barHeight - p);
        this.ctx.lineTo(sx + 2, y + barHeight - p);
        this.ctx.closePath();
        this.ctx.fill();

        if(filled) {
            // Filled segment gradient
            const grad = this.ctx.createLinearGradient(sx, y, sx, y + barHeight);
            grad.addColorStop(0, "#e57373");
            grad.addColorStop(0.5, "#c62828");
            grad.addColorStop(1, "#8e1a1a");
            this.ctx.fillStyle = grad;

            this.ctx.beginPath();
            this.ctx.moveTo(sx + 2, y + p);
            this.ctx.lineTo(sx + segW, y + p);
            this.ctx.lineTo(sx + segW, y + barHeight - p);
            this.ctx.lineTo(sx + 2, y + barHeight - p);
            this.ctx.closePath();
            this.ctx.fill();

            // Shine per segment
            this.ctx.fillStyle = "rgba(255, 255, 255, 0.25)";
            this.ctx.beginPath();
            this.ctx.moveTo(sx + 2, y + p);
            this.ctx.lineTo(sx + segW, y + p);
            this.ctx.lineTo(sx + segW, y + p + 3);
            this.ctx.lineTo(sx + 2, y + p + 3);
            this.ctx.closePath();
            this.ctx.fill();
        }
    }

    // Timer mode - smooth fill on top of segments
    if(isTimer) {
        const fillWidth = totalWidth * Math.min(fillRatio, 1);

        this.ctx.save();
        // Clip to only the filled area
        this.ctx.beginPath();
        this.ctx.rect(x - w, y, fillWidth, barHeight);
        this.ctx.clip();

        // Draw filled segments within clip
        for(let i = 0; i < maxShame; i++) {
            const sx = x - w + segmentWidth * i;
            const segW = segmentWidth - segmentGap;

            const grad = this.ctx.createLinearGradient(sx, y, sx, y + barHeight);
            grad.addColorStop(0, "#ffb74d");
            grad.addColorStop(0.5, "#f57c00");
            grad.addColorStop(1, "#bf360c");
            this.ctx.fillStyle = grad;

            this.ctx.beginPath();
            this.ctx.moveTo(sx + 2, y + p);
            this.ctx.lineTo(sx + segW, y + p);
            this.ctx.lineTo(sx + segW, y + barHeight - p);
            this.ctx.lineTo(sx + 2, y + barHeight - p);
            this.ctx.closePath();
            this.ctx.fill();

            // Shine
            this.ctx.fillStyle = "rgba(255, 255, 255, 0.25)";
            this.ctx.beginPath();
            this.ctx.moveTo(sx + 2, y + p);
            this.ctx.lineTo(sx + segW, y + p);
            this.ctx.lineTo(sx + segW, y + p + 3);
            this.ctx.lineTo(sx + 2, y + p + 3);
            this.ctx.closePath();
            this.ctx.fill();
        }

        this.ctx.restore();
    }

    // Label centered below
    this.ctx.font = "11px Hammersmith One";
    this.ctx.textBaseline = "middle";
    this.ctx.textAlign = "center";
    this.ctx.lineWidth = 2.5;
    this.ctx.lineJoin = "round";
    this.ctx.strokeStyle = "#000";
    this.ctx.strokeText(label, x, y + barHeight + 9);
    this.ctx.fillStyle = "rgba(255, 255, 255, 0.85)";
    this.ctx.fillText(label, x, y + barHeight + 9);
}

renderEntityName(e, xOffset, yOffset) {
    const text = `${e.team ? `[${e.team}] ` : ``}${e.name || ``}`;
    if (!text) return;

    this.ctx.font = `${30}px Hammersmith One`;
    this.ctx.fillStyle = "#fff";
    this.ctx.textBaseline = "middle";
    this.ctx.textAlign = "center";
    this.ctx.lineWidth = e.nameScale ? 11 : 8;
    this.ctx.lineJoin = "round";
    this.ctx.strokeStyle = "#000";

    let offset = e == playerManager.myPlayer? -10 : 0;

    const x = e.xRender - xOffset + offset;
    const y = e.yRender - yOffset - e.scale - config.nameY;

    this.ctx.strokeText(text, x, y);
    this.ctx.fillText(text, x, y);
}

renderEntityHealth(e, xOffset, yOffset) {
    if (e.health <= 0) return;

    const x = e.xRender - xOffset;
    const y = e.yRender - yOffset + e.scale + config.nameY;
    const w = config.healthBarWidth;
    const p = config.healthBarPad;
    const barHeight = 17;
    const angle = 4;

    const isAlly = e === this.myPlayer || (e.team && e.team === this.myPlayer?.team);

    // Outer glow
    this.ctx.shadowBlur = 6;
    this.ctx.shadowColor = isAlly ? "rgba(142, 204, 81, 0.3)" : "rgba(204, 81, 81, 0.3)";

    // Background
    this.ctx.fillStyle = this.darkOutlineColor;
    this.ctx.beginPath();
    this.ctx.moveTo(x - w - p + angle, y);
    this.ctx.lineTo(x + w + p - angle, y);
    this.ctx.lineTo(x + w + p, y + barHeight / 2);
    this.ctx.lineTo(x + w + p - angle, y + barHeight);
    this.ctx.lineTo(x - w - p + angle, y + barHeight);
    this.ctx.lineTo(x - w - p, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();
    this.ctx.shadowBlur = 0;

    // Health fill
    const healthWidth = w * 2 * (e.health / e.maxHealth);

    const gradient = this.ctx.createLinearGradient(x - w, y, x - w, y + barHeight);
    if(isAlly) {
        gradient.addColorStop(0, "#b8fc81");
        gradient.addColorStop(0.4, "#8ecc51");
        gradient.addColorStop(1, "#5e9431");
    } else {
        gradient.addColorStop(0, "#fc8181");
        gradient.addColorStop(0.4, "#cc5151");
        gradient.addColorStop(1, "#8c2121");
    }
    this.ctx.fillStyle = gradient;

    this.ctx.beginPath();
    this.ctx.moveTo(x - w + angle, y + p);
    this.ctx.lineTo(x - w + healthWidth - angle, y + p);
    this.ctx.lineTo(x - w + healthWidth, y + barHeight / 2);
    this.ctx.lineTo(x - w + healthWidth - angle, y + barHeight - p);
    this.ctx.lineTo(x - w + angle, y + barHeight - p);
    this.ctx.lineTo(x - w, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();

    // Shine
    if(healthWidth > angle * 2) {
        this.ctx.fillStyle = "rgba(255, 255, 255, 0.3)";
        this.ctx.beginPath();
        this.ctx.moveTo(x - w + angle, y + p);
        this.ctx.lineTo(x - w + healthWidth - angle, y + p);
        this.ctx.lineTo(x - w + healthWidth - angle, y + p + 7);
        this.ctx.lineTo(x - w + angle, y + p + 7);
        this.ctx.closePath();
        this.ctx.fill();
    }
}

renderEntityReload(e, xOffset, yOffset) {
    if(!e.isPlayer) return;

    const x = e.xRender - xOffset;
    const y = e.yRender - yOffset + e.scale + config.nameY - 13;
    const w = 23.5;
    const p = config.healthBarPad;
    const barHeight = 17;
    const angle = 3;

    const reloadGradient = this.ctx.createLinearGradient(0, y, 0, y + barHeight);
    reloadGradient.addColorStop(0, "#f8d77f");
    reloadGradient.addColorStop(0.4, "#cba24f");
    reloadGradient.addColorStop(1, "#8b6f2f");

    // Primary background
    this.ctx.fillStyle = this.darkOutlineColor;
    this.ctx.beginPath();
    this.ctx.moveTo(x - 50 - p + angle, y);
    this.ctx.lineTo(x - 50 + w * 2 + p - angle, y);
    this.ctx.lineTo(x - 50 + w * 2 + p, y + barHeight / 2);
    this.ctx.lineTo(x - 50 + w * 2 + p - angle, y + barHeight);
    this.ctx.lineTo(x - 50 - p + angle, y + barHeight);
    this.ctx.lineTo(x - 50 - p, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();

    // Primary fill
    const primaryWidth = w * 2 * e.primaryReload;
    this.ctx.fillStyle = reloadGradient;
    this.ctx.beginPath();
    this.ctx.moveTo(x - 50 + angle, y + p);
    this.ctx.lineTo(x - 50 + primaryWidth - angle, y + p);
    this.ctx.lineTo(x - 50 + primaryWidth, y + barHeight / 2);
    this.ctx.lineTo(x - 50 + primaryWidth - angle, y + barHeight - p);
    this.ctx.lineTo(x - 50 + angle, y + barHeight - p);
    this.ctx.lineTo(x - 50, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();

    // Primary shine
    if(primaryWidth > angle * 2) {
        this.ctx.fillStyle = "rgba(255, 255, 255, 0.35)";
        this.ctx.beginPath();
        this.ctx.moveTo(x - 50 + angle, y + p);
        this.ctx.lineTo(x - 50 + primaryWidth - angle, y + p);
        this.ctx.lineTo(x - 50 + primaryWidth - angle, y + p + 6);
        this.ctx.lineTo(x - 50 + angle, y + p + 6);
        this.ctx.closePath();
        this.ctx.fill();
    }

    // Secondary background
    this.ctx.fillStyle = this.darkOutlineColor;
    this.ctx.beginPath();
    this.ctx.moveTo(x + 2 - p + angle, y);
    this.ctx.lineTo(x + 2 + w * 2 + p - angle, y);
    this.ctx.lineTo(x + 2 + w * 2 + p, y + barHeight / 2);
    this.ctx.lineTo(x + 2 + w * 2 + p - angle, y + barHeight);
    this.ctx.lineTo(x + 2 - p + angle, y + barHeight);
    this.ctx.lineTo(x + 2 - p, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();

    // Secondary fill
    const secondaryWidth = w * 2 * e.secondaryReload;
    this.ctx.fillStyle = reloadGradient;
    this.ctx.beginPath();
    this.ctx.moveTo(x + 2 + angle, y + p);
    this.ctx.lineTo(x + 2 + secondaryWidth - angle, y + p);
    this.ctx.lineTo(x + 2 + secondaryWidth, y + barHeight / 2);
    this.ctx.lineTo(x + 2 + secondaryWidth - angle, y + barHeight - p);
    this.ctx.lineTo(x + 2 + angle, y + barHeight - p);
    this.ctx.lineTo(x + 2, y + barHeight / 2);
    this.ctx.closePath();
    this.ctx.fill();

    // Secondary shine
    if(secondaryWidth > angle * 2) {
        this.ctx.fillStyle = "rgba(255, 255, 255, 0.35)";
        this.ctx.beginPath();
        this.ctx.moveTo(x + 2 + angle, y + p);
        this.ctx.lineTo(x + 2 + secondaryWidth - angle, y + p);
        this.ctx.lineTo(x + 2 + secondaryWidth - angle, y + p + 6);
        this.ctx.lineTo(x + 2 + angle, y + p + 6);
        this.ctx.closePath();
        this.ctx.fill();
    }
}
    // ============================================================================
    // SPRITES
    // ============================================================================

    getResSprite(obj) {
        const biome = this.getBiome(obj.y);
        const key = `${obj.type}_${obj.scale}_${biome}`;
        return this.sprites.gameObject[key] ||= this.createResSprite(obj, biome);
    }

    createResSprite(obj, biome) {
        const canvas = document.createElement('canvas');
        canvas.width = canvas.height = obj.scale * 2.1 + this.outlineWidth;
        const ctx = canvas.getContext('2d');

        ctx.translate(canvas.width / 2, canvas.height / 2);
        ctx.rotate(UTILS.randFloat(0, Math.PI));
        ctx.strokeStyle = this.outlineColor;
        ctx.lineWidth = this.outlineWidth;

        const s = obj.scale;
        switch (obj.type) {
            case 0: // Tree
                for (let i = 0; i < 2; i++) {
                    const scale = s * (!i ? 1 : 0.5);
                    this.renderStar(ctx, 7, scale, scale * 0.7);
                    ctx.fillStyle = !biome ? (!i ? "#9ebf57" : "#b4db62") : (!i ? "#e3f1f4" : "#fff");
                    ctx.fill();
                    if (!i) ctx.stroke();
                }
                break;
            case 1: // Bush
                if (biome === 2) {
                    ctx.fillStyle = "#606060";
                    this.renderStar(ctx, 6, s * 0.3, s * 0.71);
                    ctx.fill();
                    ctx.stroke();
                    ctx.fillStyle = "#89a54c";
                    this.renderCircle(0, 0, s * 0.55, ctx);
                    ctx.fillStyle = "#a5c65b";
                    this.renderCircle(0, 0, s * 0.3, ctx, true);
                } else {
                    this.renderBlob(ctx, 6, s, s * 0.7);
                    ctx.fillStyle = biome ? "#e3f1f4" : "#89a54c";
                    ctx.fill();
                    ctx.stroke();
                    ctx.fillStyle = biome ? "#6a64af" : "#c15555";
                    for (let i = 0; i < 4; i++) {
                        const r = UTILS.randInt(s / 3.5, s / 2.3);
                        const angle = (Math.PI * 2 / 4) * i;
                        this.renderCircle(r * Math.cos(angle), r * Math.sin(angle), UTILS.randInt(10, 12), ctx);
                    }
                }
                break;
            case 2:
            case 3: // Rock
                ctx.fillStyle = obj.type === 2 ? (biome === 2 ? "#938d77" : "#939393") : "#e0c655";
                this.renderStar(ctx, 3, s, s);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = obj.type === 2 ? (biome === 2 ? "#b2ab90" : "#bcbcbc") : "#ebdca3";
                this.renderStar(ctx, 3, s * 0.55, s * 0.65);
                ctx.fill();
                break;
        }

        return canvas;
    }

    getItemSprite(obj, asIcon) {
        let sprite = this.sprites.item[obj.id];
        if (!sprite || asIcon) {
            const canvas = document.createElement('canvas');
            const size = obj.scale * 2.5 + this.outlineWidth + (items.list[obj.id].spritePadding || 0);
            canvas.width = canvas.height = size;
            const ctx = canvas.getContext('2d');
            ctx.translate(size / 2, size / 2);
            ctx.rotate(asIcon ? 0 : Math.PI / 2);
            ctx.strokeStyle = this.outlineColor;
            ctx.lineWidth = this.outlineWidth * (asIcon ? size / 81 : 1);

            this.drawItemSprite(obj, ctx);
            sprite = canvas;
            if (!asIcon) this.sprites.item[obj.id] = sprite;
        }
        return sprite;
    }

    drawItemSprite(obj, ctx) {
        const s = obj.scale;
        const renderChips = (color, count) => {
            ctx.fillStyle = color;
            for (let i = 0; i < count; i++) {
                const r = UTILS.randInt(s / 2.5, s / 1.7);
                const angle = (Math.PI * 2 / count) * i;
                this.renderCircle(r * Math.cos(angle), r * Math.sin(angle), UTILS.randInt(4, 5), ctx, true);
            }
        };

        switch (obj.name) {
            case "apple":
                ctx.fillStyle = "#c15555";
                this.renderCircle(0, 0, s, ctx);
                ctx.fillStyle = "#89a54c";
                const leafDir = -Math.PI / 2;
                this.renderLeaf(s * Math.cos(leafDir), s * Math.sin(leafDir), 25, leafDir + Math.PI / 2, ctx);
                break;
            case "cookie":
                ctx.fillStyle = "#cca861";
                this.renderCircle(0, 0, s, ctx);
                renderChips("#937c4b", 4);
                break;
            case "cheese":
                ctx.fillStyle = "#f4f3ac";
                this.renderCircle(0, 0, s, ctx);
                renderChips("#c3c28b", 4);
                break;
            case "wood wall":
            case "stone wall":
            case "castle wall":
                const isCastle = obj.name === "castle wall";
                const isWood = obj.name === "wood wall";
                ctx.fillStyle = isCastle ? "#83898e" : isWood ? "#a5974c" : "#939393";
                this.renderStar(ctx, isCastle ? 4 : 3, s * 1.1, s * 1.1);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = isCastle ? "#9da4aa" : isWood ? "#c9b758" : "#bcbcbc";
                this.renderStar(ctx, isCastle ? 4 : 3, s * 0.65, s * 0.65);
                ctx.fill();
                break;
            case "spikes":
            case "greater spikes":
            case "poison spikes":
            case "spinning spikes":
                ctx.fillStyle = obj.name === "poison spikes" ? "#7b935d" : "#939393";
                this.renderStar(ctx, obj.name === "spikes" ? 5 : 6, s, s * 0.6);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = "#a5974c";
                this.renderCircle(0, 0, s * 0.6, ctx);
                ctx.fillStyle = "#c9b758";
                this.renderCircle(0, 0, s * 0.3, ctx, true);
                break;
            case "windmill":
            case "faster windmill":
            case "power mill":
                ctx.fillStyle = "#a5974c";
                this.renderCircle(0, 0, s, ctx);
                ctx.fillStyle = "#c9b758";
                this.renderRectCircle(0, 0, s * 1.5, 29, 4, ctx);
                ctx.fillStyle = "#a5974c";
                this.renderCircle(0, 0, s * 0.5, ctx);
                break;
            case "mine":
                ctx.fillStyle = "#939393";
                this.renderStar(ctx, 3, s, s);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = "#bcbcbc";
                this.renderStar(ctx, 3, s * 0.55, s * 0.65);
                ctx.fill();
                break;
            case "sapling":
                for (let i = 0; i < 2; i++) {
                    this.renderStar(ctx, 7, s * (!i ? 1 : 0.5), s * (!i ? 0.7 : 0.35));
                    ctx.fillStyle = !i ? "#9ebf57" : "#b4db62";
                    ctx.fill();
                    if (!i) ctx.stroke();
                }
                break;
            case "pit trap":
                ctx.fillStyle = "#a5974c";
                this.renderStar(ctx, 3, s * 1.1, s * 1.1);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = this.outlineColor;
                this.renderStar(ctx, 3, s * 0.65, s * 0.65);
                ctx.fill();
                break;
            case "boost pad":
                ctx.fillStyle = "#7e7f82";
                this.renderRect(0, 0, s * 2, s * 2, ctx);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = "#dbd97d";
                this.renderTriangle(s * 1, ctx);
                break;
            case "turret":
                ctx.fillStyle = "#a5974c";
                this.renderCircle(0, 0, s, ctx);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = "#939393";
                this.renderRect(0, -25, s * 0.9, 50, ctx);
                this.renderCircle(0, 0, s * 0.6, ctx);
                ctx.fill();
                ctx.stroke();
                break;
            case "platform":
                ctx.fillStyle = "#cebd5f";
                for (let i = 0; i < 4; i++) {
                    const x = -s / 2 + (s * 2 / 4) * i;
                    this.renderRect(x, 0, s * 2 / 4, s * 2, ctx);
                    ctx.fill();
                    ctx.stroke();
                }
                break;
            case "healing pad":
                ctx.fillStyle = "#7e7f82";
                this.renderRect(0, 0, s * 2, s * 2, ctx);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = "#db6e6e";
                this.renderRectCircle(0, 0, s * 0.65, 20, 4, ctx, true);
                break;
            case "spawn pad":
                ctx.fillStyle = "#7e7f82";
                this.renderRect(0, 0, s * 2, s * 2, ctx);
                ctx.fill();
                ctx.stroke();
                ctx.fillStyle = "#71aad6";
                this.renderCircle(0, 0, s * 0.6, ctx);
                break;
            case "blocker":
                ctx.fillStyle = "#7e7f82";
                this.renderCircle(0, 0, s, ctx);
                ctx.fill();
                ctx.stroke();
                ctx.rotate(Math.PI / 4);
                ctx.fillStyle = "#db6e6e";
                this.renderRectCircle(0, 0, s * 0.65, 20, 4, ctx, true);
                break;
            case "teleporter":
                ctx.fillStyle = "#7e7f82";
                this.renderCircle(0, 0, s, ctx);
                ctx.fill();
                ctx.stroke();
                ctx.rotate(Math.PI / 4);
                ctx.fillStyle = "#d76edb";
                this.renderCircle(0, 0, s * 0.5, ctx, true);
                break;
        }
    }

    renderSkin(idx, ctxt, parent, owner) {
        let sprite = this.sprites.skin[idx] ||= this.loadImg(`.././img/hats/hat_${idx}.png`);
        let obj = parent || (this.sprites.skinPointers[idx] ||= this.findInShop(idx, 'hats'));

        if (sprite.isLoaded && obj) {
            ctxt.drawImage(sprite, -obj.scale / 2, -obj.scale / 2, obj.scale, obj.scale);
        }

        if (!parent && obj?.topSprite) {
            ctxt.save();
            ctxt.rotate(owner.skinRot);
            this.renderSkin(idx + "_top", ctxt, obj, owner);
            ctxt.restore();
        }
    }

    renderTail(idx, ctxt, owner) {
        let sprite = this.sprites.access[idx] ||= this.loadImg(`.././img/accessories/access_${idx}.png`);
        let obj = this.sprites.accessPointers[idx] ||= this.findInShop(idx, 'accessories');

        if (sprite.isLoaded) {
            ctxt.save();
            ctxt.translate(-20 - (obj.xOff || 0), 0);
            if (obj.spin) ctxt.rotate(owner.skinRot);
            ctxt.drawImage(sprite, -obj.scale / 2, -obj.scale / 2, obj.scale, obj.scale);
            ctxt.restore();
        }
    }

    renderTool(obj, variant, x, y, ctxt) {
        const key = obj.src + (variant || "");
        let sprite = this.sprites.tool[key] ||= this.loadImg(`.././img/weapons/${key}.png`);

        if (sprite.isLoaded) {
            ctxt.drawImage(sprite, x + obj.xOff - obj.length / 2, y + obj.yOff - obj.width / 2, obj.length, obj.width);
        }
    }

    renderProjectile(x, y, obj, ctxt) {
        if (obj.src) {
            const key = items.projectiles[obj.indx].src;
            let sprite = this.sprites.projectile[key] ||= this.loadImg(`.././img/weapons/${key}.png`);
            if (sprite.isLoaded) ctxt.drawImage(sprite, x - obj.scale / 2, y - obj.scale / 2, obj.scale, obj.scale);
        } else if (obj.indx === 1) {
            ctxt.fillStyle = "#939393";
            this.renderCircle(x, y, obj.scale, ctxt);
        }
    }

    loadImg(src) {
        const img = new Image();
        img.onload = function() { this.isLoaded = true; this.onload = null; };
        img.src = src;
        return img;
    }

    findInShop(idx, type) {
        return shop?.[type]?.find(item => item.id == idx) || null;
    }

    // ============================================================================
    // SHAPES
    // ============================================================================

    renderCircle(x, y, r, ctx = this.ctx, noStroke, noFill) {
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        if (!noFill) ctx.fill();
        if (!noStroke) ctx.stroke();
    }

    renderStar(ctx, spikes, outer, inner) {
        const step = Math.PI / spikes;
        let angle = Math.PI * 1.5;

        ctx.beginPath();
        ctx.moveTo(0, -outer);

        for (let i = 0; i < spikes; i++) {
            ctx.lineTo(Math.cos(angle) * outer, Math.sin(angle) * outer);
            angle += step;
            ctx.lineTo(Math.cos(angle) * inner, Math.sin(angle) * inner);
            angle += step;
        }

        ctx.lineTo(0, -outer);
        ctx.closePath();
    }

    renderBlob(ctx, spikes, outer, inner) {
        const step = Math.PI / spikes;
        let angle = Math.PI * 1.5;

        ctx.beginPath();
        ctx.moveTo(0, -inner);

        for (let i = 0; i < spikes; i++) {
            const tmpOuter = UTILS.randInt(outer * 0.9, outer * 1.2);
            ctx.quadraticCurveTo(
                Math.cos(angle + step) * tmpOuter,
                Math.sin(angle + step) * tmpOuter,
                Math.cos(angle + step * 2) * inner,
                Math.sin(angle + step * 2) * inner
            );
            angle += step * 2;
        }

        ctx.lineTo(0, -inner);
        ctx.closePath();
    }

    renderRectCircle(x, y, s, sw, seg, ctx, stroke) {
        ctx.save();
        ctx.translate(x, y);
        seg = Math.ceil(seg / 2);
        for (let i = 0; i < seg; i++) {
            this.renderRect(0, 0, s * 2, sw, ctx, stroke);
            ctx.rotate(Math.PI / seg);
        }
        ctx.restore();
    }

    renderRect(x, y, w, h, ctx, stroke) {
        ctx.fillRect(x - w / 2, y - h / 2, w, h);
        if (!stroke) ctx.strokeRect(x - w / 2, y - h / 2, w, h);
    }

    renderLeaf(x, y, l, r, ctx) {
        const endX = x + l * Math.cos(r);
        const endY = y + l * Math.sin(r);
        const w = l * 0.4;
        ctx.beginPath();
        ctx.quadraticCurveTo(
            (x + endX) / 2 + w * Math.cos(r + Math.PI / 2),
            (y + endY) / 2 + w * Math.sin(r + Math.PI / 2),
            endX, endY
        );
        ctx.quadraticCurveTo(
            (x + endX) / 2 - w * Math.cos(r + Math.PI / 2),
            (y + endY) / 2 - w * Math.sin(r + Math.PI / 2),
            x, y
        );
        ctx.closePath();
        ctx.fill();
        ctx.stroke();
    }

    renderTriangle(s, ctx = this.ctx) {
        const h = s * (Math.sqrt(3) / 2);
        ctx.beginPath();
        ctx.moveTo(0, -h / 2);
        ctx.lineTo(-s / 2, h / 2);
        ctx.lineTo(s / 2, h / 2);
        ctx.lineTo(0, -h / 2);
        ctx.fill();
        ctx.closePath();
    }

    // ============================================================================
    // UTILS
    // ============================================================================

    getBiome(y) {
        if (y >= config.mapScale - config.snowBiomeTop) return 2;
        if (y <= config.snowBiomeTop) return 1;
        return 0;
    }

    isOnScreen(x, y, buffer = 0) {
        return x + buffer >= 0 && x - buffer <= config.maxScreenWidth &&
            y + buffer >= 0 && y - buffer <= config.maxScreenHeight;
    }

    fillScreen(color) {
        this.ctx.fillStyle = color;
        this.ctx.fillRect(0, 0, config.maxScreenWidth, config.maxScreenHeight);
    }
}

class AnimText {
    constructor() {
        this.x = 0;
        this.y = 0;
        this.color = "";
        this.scale = 0;
        this.startScale = 0;
        this.maxScale = 0;
        this.scaleSpeed = 0;
        this.speed = 0;
        this.life = 0;
        this.text = "";
    }

    init(x, y, scale, speed, life, text, color) {
        this.x = x;
        this.y = y;
        this.color = color;
        this.scale = scale;
        this.startScale = scale;
        this.maxScale = scale * 1.5;
        this.scaleSpeed = 0.7;
        this.speed = speed;
        this.life = life;
        this.text = text;
    }

    update(delta) {
        if (this.life) {
            this.life -= delta;
            this.y -= this.speed * delta;
            this.scale += this.scaleSpeed * delta;

            if (this.scale >= this.maxScale) {
                this.scale = this.maxScale;
                this.scaleSpeed *= -1;
            } else if (this.scale <= this.startScale) {
                this.scale = this.startScale;
                this.scaleSpeed = 0;
            }

            if (this.life <= 0) {
                this.life = 0;
            }
        }
    }

    render(ctx, xOff, yOff) {
        ctx.fillStyle = this.color;
        ctx.font = this.scale + "px Hammersmith One";
        ctx.fillText(this.text, this.x - xOff, this.y - yOff);
    }
}

class TextManager {
    constructor() {
        this.texts = [];
    }

    showDamageText(x, y, value, type) {
        this.showText(
            x,
            y,
            50,
            0.18,
            500,
            Math.abs(value),
            (value >= 0) ? "#fff" : "#8ecc51"
        );
    }

    update(delta, ctx, xOff, yOff) {
        ctx.textBaseline = "middle";
        ctx.textAlign = "center";

        for (let i = 0; i < this.texts.length; i++) {
            if (this.texts[i].life) {
                this.texts[i].update(delta);
                this.texts[i].render(ctx, xOff, yOff);
            }
        }
    }

    showText(x, y, scale, speed, life, text, color) {
        let tmpText;

        for (let i = 0; i < this.texts.length; i++) {
            if (!this.texts[i].life) {
                tmpText = this.texts[i];
                break;
            }
        }

        if (!tmpText) {
            tmpText = new AnimText();
            this.texts.push(tmpText);
        }

        tmpText.init(x, y, scale, speed, life, text, color);
    }
}

