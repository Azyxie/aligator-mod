class Shame {
    manageTimer() {
         for(const player of playerManager.players){
            if(player.skinIndex == 45){
                if(player.shameTimer == 0) player.shameTimer = 30000;
                player.shameCount = 8;
            } else {
                if(player.shameTimer > 0){
                    player.shameCount = 0;
                    player.shameTimer = 0;
                }
            }
            if(player.shameTimer > 0) player.shameTimer = Math.max(0, player.shameTimer - config.tickRate);
        }
    }

    calculate(player) {
        if(player.lastHealTick == tickManager.count) return;
        player.lastHealTick = tickManager.count;
        const difference = player.lastHealTime - player.lastDamageTime;
        if(difference > 120) {
            player.shameCount = Math.max(0, player.shameCount - 2);
        } else {
            player.shameCount += 1;
        }
    }
