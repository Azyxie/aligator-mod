class Placer {
    constructor() {
        this.preplaceObjects = [];
        this.prePlaceAngles = [];
        this.autoPlaceAngles = [];
        this.trapSpot = null;
        this.spikeSpot = null;
        this.placeAngles = [];
        this.placedObjects = [];
        this.lastTime = 0;
    }

    autoPlacer() {
        this.autoPlaceAngles = [];
        const {nearestEnemy} = playerManager;
        if(!nearestEnemy) return;
        const {myPlayer} = playerManager;
        if(!myPlayer) return;
        const distToEnemy = UTILS.getDistance(nearestEnemy.x2, nearestEnemy.y2, myPlayer.x2, myPlayer.y2);
        if(distToEnemy > 300) return;

        // Early exit if no items
        if(!this.trapSpot && !this.spikeSpot) return;

        if(!settings.autoplacer) return;

        // Run autoplace angles
        const allAngles = this.getAutoPlaceAngles(objectManager.visibleObjects);
        this.autoPlaceAngles = this.selectBestAngles(allAngles);
    }

    getAutoPlaceAngles(objects) {
        const {myPlayer} = playerManager;
        const baseAngleCount = 36;
        const angleStep = (Math.PI * 2) / baseAngleCount;
        const subdivisions = 4;
        
        const tmpAngles = [];
        const baseAngles = Array.from({length: baseAngleCount}, (_, i) => i * angleStep);
        
        const trapTransitions = new Set();
        const spikeTransitions = new Set();
        let prevTrapPlaceable = null;
        let prevSpikePlaceable = null;
        
        // First pass: base angles
        for(let i = 0; i < baseAngleCount; i++) {
            const angle = baseAngles[i];
            
            if(this.trapSpot) {
                const placeable = this.canPlace(15, angle, objects);
                if(prevTrapPlaceable !== null && prevTrapPlaceable !== placeable) {
                    trapTransitions.add(i);
                }
                prevTrapPlaceable = placeable;
                
                tmpAngles.push({ 
                    id: 15, 
                    angle,
                    preplace: false,
                    placeable,
                    ...this.getPredictObject(15, angle)
                });
            }
            
            if(this.spikeSpot) {
                const placeable = this.canPlace(9, angle, objects);
                if(prevSpikePlaceable !== null && prevSpikePlaceable !== placeable) {
                    spikeTransitions.add(i);
                }
                prevSpikePlaceable = placeable;
                
                tmpAngles.push({ 
                    id: 9,
                    angle,
                    preplace: false,
                    placeable,
                    ...this.getPredictObject(9, angle)
                });
            }
        }
        
        // Second pass: refine transitions only
        const refinementIndices = new Set([...trapTransitions, ...spikeTransitions]);
        
        for(let idx of refinementIndices) {
            const prevIdx = (idx - 1 + baseAngleCount) % baseAngleCount;
            const startAngle = baseAngles[prevIdx];
            const endAngle = baseAngles[idx];
            
            let angleDiff = endAngle - startAngle;
            if(angleDiff < 0) angleDiff += Math.PI * 2;
            
            const stepSize = angleDiff / subdivisions;
            
            for(let j = 1; j < subdivisions; j++) {
                let refinedAngle = startAngle + stepSize * j;
                if(refinedAngle > Math.PI * 2) refinedAngle -= Math.PI * 2;
                
                if(this.trapSpot) {
                    tmpAngles.push({ 
                        id: 15,
                        angle: refinedAngle,
                        preplace: false,
                        placeable: this.canPlace(15, refinedAngle, objects),
                        ...this.getPredictObject(15, refinedAngle)
                    });
                }
                
                if(this.spikeSpot) {
                    tmpAngles.push({ 
                        id: 9,
                        angle: refinedAngle,
                        preplace: false,
                        placeable: this.canPlace(9, refinedAngle, objects),
                        ...this.getPredictObject(9, refinedAngle)
                    });
                }
            }
        }
        
        return tmpAngles;
    }

    prePlacer() {
        this.prePlaceAngles = [];
        const {nearestEnemy} = playerManager;
        if(!nearestEnemy) return;
        const {myPlayer} = playerManager;
        if(!myPlayer) return;
        const distToEnemy = UTILS.getDistance(nearestEnemy.x2, nearestEnemy.y2, myPlayer.x2, myPlayer.y2);
        if(distToEnemy > 300) return;

        // Get preplace items
        this.trapSpot = this.getObjInInventory(15);
        this.spikeSpot = this.getObjInInventory(9);

        // Early exit if no items
        if(!this.trapSpot && !this.spikeSpot) return;

        if(!settings.preplacer) return;

        // Get preplace objects (max 2)
        this.preplaceObjects = this.getPrePlaceObjects();
        
        // Run angles for each preplace object separately
        for(let object of this.preplaceObjects) {
            // Filter out current object from collision check
            const objects = objectManager.visibleObjects.filter(obj => obj !== object);
            const objectAngles = this.getPrePlaceAngles(objects, object);
            
            // Select best angles for THIS preplace object
            const selectedAngles = this.selectBestAngles(objectAngles);
            
            // Combine into final array
            this.prePlaceAngles.push(...selectedAngles);
        }
    }

    getPrePlaceAngles(objects, preplaceObject) {
        const {myPlayer} = playerManager;
        const baseAngleCount = 36;
        const angleStep = (Math.PI * 2) / baseAngleCount;
        const subdivisions = 4;
        
        const tmpAngles = [];
        const baseAngles = Array.from({length: baseAngleCount}, (_, i) => i * angleStep);
        
        // Calculate if angle is within preplace object radius
        const isAngleNearObject = (angle) => {
            const checkDist = 150;
            const px = myPlayer.x + Math.cos(angle) * checkDist;
            const py = myPlayer.y + Math.sin(angle) * checkDist;
            const dist = UTILS.getDistance(px, py, preplaceObject.x, preplaceObject.y);
            return dist <= preplaceObject.scale * 2;
        };
        
        const trapTransitions = new Set();
        const spikeTransitions = new Set();
        const nearObjectIndices = new Set();
        let prevTrapPlaceable = null;
        let prevSpikePlaceable = null;
        
        // First pass: base angles
        for(let i = 0; i < baseAngleCount; i++) {
            const angle = baseAngles[i];
            
            if(isAngleNearObject(angle)) {
                nearObjectIndices.add(i);
            }
            
            if(this.trapSpot) {
                const placeable = this.canPlace(15, angle, objects);
                if(prevTrapPlaceable !== null && prevTrapPlaceable !== placeable) {
                    trapTransitions.add(i);
                }
                prevTrapPlaceable = placeable;
                
                tmpAngles.push({ 
                    id: 15, 
                    angle,
                    preplace: true,
                    placeable,
                    preplaceObject,
                    ...this.getPredictObject(15, angle)
                });
            }
            
            if(this.spikeSpot) {
                const placeable = this.canPlace(9, angle, objects);
                if(prevSpikePlaceable !== null && prevSpikePlaceable !== placeable) {
                    spikeTransitions.add(i);
                }
                prevSpikePlaceable = placeable;
                
                tmpAngles.push({ 
                    id: 9,
                    angle,
                    preplace: true,
                    placeable,
                    preplaceObject,
                    ...this.getPredictObject(9, angle)
                });
            }
        }
        
        // Second pass: refine transitions and near-object angles
        const refinementIndices = new Set([...trapTransitions, ...spikeTransitions, ...nearObjectIndices]);
        
        for(let idx of refinementIndices) {
            const prevIdx = (idx - 1 + baseAngleCount) % baseAngleCount;
            const startAngle = baseAngles[prevIdx];
            const endAngle = baseAngles[idx];
            
            let angleDiff = endAngle - startAngle;
            if(angleDiff < 0) angleDiff += Math.PI * 2;
            
            const stepSize = angleDiff / subdivisions;
            
            for(let j = 1; j < subdivisions; j++) {
                let refinedAngle = startAngle + stepSize * j;
                if(refinedAngle > Math.PI * 2) refinedAngle -= Math.PI * 2;
                
                if(this.trapSpot) {
                    tmpAngles.push({ 
                        id: 15,
                        angle: refinedAngle,
                        preplace: true,
                        placeable: this.canPlace(15, refinedAngle, objects),
                        preplaceObject,
                        ...this.getPredictObject(15, refinedAngle)
                    });
                }
                
                if(this.spikeSpot) {
                    tmpAngles.push({ 
                        id: 9,
                        angle: refinedAngle,
                        preplace: true,
                        placeable: this.canPlace(9, refinedAngle, objects),
                        preplaceObject,
                        ...this.getPredictObject(9, refinedAngle)
                    });
                }
            }
        }
        
        return tmpAngles;
    }

    updateAutoPlaceBans() {
    if(!this.autoPlaceBans) return;
    
        // Decrement tick counters
        for(let [key, ban] of this.autoPlaceBans) {
            ban.ticksRemaining--;
            if(ban.ticksRemaining <= 0) {
                this.autoPlaceBans.delete(key);
            }
        }
    }

    isAngleBanned(id, angle) {
        if(!this.autoPlaceBans) return false;
        const angleKey = `${id}_${angle.toFixed(3)}`;
        return this.autoPlaceBans.has(angleKey);
    }

place(tmpTime) {
    const allAngles = [...this.prePlaceAngles, ...(this.autoPlaceAngles || [])];
    this.getPlaceAngles(allAngles);

    const timeNow = performance.now();
    const timeSinceBreak = timeNow - tmpTime;

    this.placedObjects = [];
    
    if(this.placeAngles.length === 0) return;

    // Separate preplace and autoplace angles
    const preplaceAngles = this.placeAngles.filter(obj => obj.preplace);
    const autoplaceAngles = this.placeAngles.filter(obj => !obj.preplace);
    
    // Place autoplace angles immediately
    for(let object of autoplaceAngles) {
        this.placedObjects.push(object);
        place.send(object.id, object.angle);
        game.selectWeapon(weapon.predictWeapon);
        
        if(!this.autoPlaceBans) this.autoPlaceBans = new Map();
        const angleKey = `${object.id}_${object.angle.toFixed(3)}`;
        this.autoPlaceBans.set(angleKey, {
            angle: object.angle,
            id: object.id,
            ticksRemaining: 10
        });
    }
    if(this.placedObjects.length > 0) {
        game.sendDir(dir.predictDir);
    }
    
    // Only place preplace angles where object is ready
    const readyPreplaceAngles = preplaceAngles.filter(angle => 
        angle.preplaceObject && angle.preplaceObject.readyToPreplace
    );
    
    if(readyPreplaceAngles.length > 0) {
        const delay3 = config.tickRate - (timeSinceBreak % config.tickRate) - pingTracker.prePlacePing;
        
        setTimeout(() => {
            for(let object of readyPreplaceAngles) {
                this.placedObjects.push(object);
                place.send(object.id, object.angle);
                game.selectWeapon(weapon.predictWeapon);
            }
            game.sendDir(dir.predictDir);
        }, delay3);
    }
}

    selectBestAngles(allAngles) {
        const {myPlayer} = playerManager;
        const {nearestEnemy} = playerManager;
        
        const placeableAngles = allAngles.filter(angle => angle.placeable);
        if(placeableAngles.length === 0) return [];
        
        const scoredAngles = placeableAngles.map(angle => {
            const isSpike = angle.id === 9;
            const isTrap = angle.id === 15;
            const distToEnemy = UTILS.getDistance(angle.x, angle.y, nearestEnemy.x2, nearestEnemy.y2);
            const touchEnemy = distToEnemy < nearestEnemy.scale + angle.scale;
            const trapEnemy = distToEnemy < 50;

            if(angle.preplace) {
                //
                const distToObj = UTILS.getDistance(angle.x, angle.y, angle.preplaceObject.x, angle.preplaceObject.y);

                 // First priority: spike near enemy trap (1000-1200)
                if(nearestEnemy.trap && angle.preplaceObject !== nearestEnemy.trap && isSpike && touchEnemy) {
                    return { ...angle, score: 1000 + (200 - Math.min(200, distToEnemy)) };
                }

                // Second priority: spike enemy into other spikes (500-700)
                if(nearestEnemy.trap && angle.preplaceObject == nearestEnemy.trap && isSpike && touchEnemy) {
                    const spikes = objectManager.allySpikes;
                    
                    let bestAlignment = 0;
                    
                    for(let spike of spikes) {
                        if(UTILS.getDistance(spike.x, spike.y, nearestEnemy.x2, nearestEnemy.y2) > 150) continue;

                        const spikeToEnemyAngle = UTILS.getDirection(nearestEnemy.x2, nearestEnemy.y2, spike.x, spike.y);
                        const enemyToNewSpikeAngle = UTILS.getDirection(angle.x, angle.y, nearestEnemy.x2, nearestEnemy.y2);
                        const alignment = Math.abs(UTILS.getAngleDist(spikeToEnemyAngle, enemyToNewSpikeAngle));
                        
                        if(alignment < Math.PI / 6) {
                            bestAlignment = Math.max(bestAlignment, (Math.PI / 4 - alignment) / (Math.PI / 4));
                        }
                    }
                    
                    if(bestAlignment > 0) {
                        return { ...angle, score: 500 + bestAlignment * 200 };
                    }
                }

                // Third priority: enemy is trapped, place spikes (300-550)
                if(nearestEnemy.trap && angle.preplaceObject !== nearestEnemy.trap && isSpike) {
                    const playerFutureX = myPlayer.x + Math.cos(move.predictAngle) * 100;
                    const playerFutureY = myPlayer.y + Math.sin(move.predictAngle) * 100;
                    
                    const wouldBlock = UTILS.lineInRect(
                        angle.x - angle.scale, angle.y - angle.scale,
                        angle.x + angle.scale, angle.y + angle.scale,
                        myPlayer.x, myPlayer.y,
                        playerFutureX, playerFutureY
                    );
                    
                    if(!wouldBlock) {
                        return { ...angle, score: 300 + (250 - Math.min(250, distToObj)) };
                    }
                }

                // Last priority: trap near enemy (5-255)
                if(isTrap) {
                    return { ...angle, score: 5 + (250 - Math.min(250, distToObj)) };
                }
            } else {
                // First priority: spike trapped enemy
                if(nearestEnemy.trap && touchEnemy && isSpike) {
                    return { ...angle, score: 1000 + (200 - Math.min(200, distToEnemy)) };
                }

                // Second priority: spike enemy into other spikes
                if(isSpike && touchEnemy) {
                    const spikes = objectManager.allySpikes;
                    
                    let bestAlignment = 0;
                    
                    for(let spike of spikes) {
                        if(UTILS.getDistance(spike.x, spike.y, nearestEnemy.x2, nearestEnemy.y2) > 150) continue;

                        const spikeToEnemyAngle = UTILS.getDirection(nearestEnemy.x2, nearestEnemy.y2, spike.x, spike.y);
                        const enemyToNewSpikeAngle = UTILS.getDirection(angle.x, angle.y, nearestEnemy.x2, nearestEnemy.y2);
                        const alignment = Math.abs(UTILS.getAngleDist(spikeToEnemyAngle, enemyToNewSpikeAngle));
                        
                        if(alignment < Math.PI / 4) {
                            bestAlignment = Math.max(bestAlignment, (Math.PI / 4 - alignment) / (Math.PI / 4));
                        }
                    }
                    
                    if(bestAlignment > 0) { 
                        return { ...angle, score: 500 + bestAlignment * 200 };
                    }
                }

                // Third priority: place spikes if enemy trapped and they dont obf our sight
                if(nearestEnemy.trap && isSpike) {
                    const playerFutureX = myPlayer.x + Math.cos(move.predictAngle) * 100;
                    const playerFutureY = myPlayer.y + Math.sin(move.predictAngle) * 100;
                    
                    const wouldBlock = UTILS.lineInRect(
                        angle.x - angle.scale, angle.y - angle.scale,
                        angle.x + angle.scale, angle.y + angle.scale,
                        myPlayer.x, myPlayer.y,
                        playerFutureX, playerFutureY
                    );
                    
                    if(!wouldBlock) {
                        return { ...angle, score: 300 + (250 - Math.min(250, distToEnemy)) };
                    }
                }

                // Place traps
                if(!nearestEnemy.trap && isTrap) {
                    return { ...angle, score: 5 + (250 - Math.min(250, distToEnemy)) };
                }
            }
            return { ...angle, score: 0 };
        });
        
        return scoredAngles.sort((a, b) => b.score - a.score);
    }

    getPlaceAngles(angles) {
    this.placeAngles = [];
    let maxPlacements = 3;
    if (packetCounter.packets > 100) {
        maxPlacements = 2;
    }

    // Separate preplace and autoplace angles, filter out zero scores
    const preplaceAngles = angles.filter(a => a.preplace && a.score > 0);
    const autoplaceAngles = (this.autoPlaceAngles || []).filter(
        a => a.score > 0 && !this.isAngleBanned(a.id, a.angle)
    );

    // Group preplace angles by preplace object
    const anglesByPreplace = new Map();
    for (let angle of preplaceAngles) {
        if (!anglesByPreplace.has(angle.preplaceObject)) {
            anglesByPreplace.set(angle.preplaceObject, []);
        }
        anglesByPreplace.get(angle.preplaceObject).push(angle);
    }

    // Get the best angle for each preplace object
    const bestPreplaceAngles = [];
    for (let [preplaceObj, objAngles] of anglesByPreplace) {
        const sorted = objAngles.sort((a, b) => b.score - a.score);
        if (sorted.length > 0) {
            bestPreplaceAngles.push(sorted[0]);
        }
    }

    // Sort best preplace angles by score
    bestPreplaceAngles.sort((a, b) => b.score - a.score);

    // Add non-overlapping preplace angles (priority)
    for (let angle of bestPreplaceAngles) {
        if (this.placeAngles.length >= maxPlacements) break;

        const overlaps = this.placeAngles.some(placedAngle => {
            const dist = UTILS.getDistance(angle.x, angle.y, placedAngle.x, placedAngle.y);
            return dist <= angle.scale + placedAngle.scale;
        });

        if (!overlaps) {
            this.placeAngles.push(angle);
        }
    }

    // Store current preplace angles as last preplace
    if (this.placeAngles.length > 0) {
        this.lastPreplaceAngles = this.placeAngles.map(a => ({
            x: a.x,
            y: a.y,
            scale: a.scale
        }));
    }

    // Add autoplace angles if there's room
    if (this.placeAngles.length < maxPlacements && autoplaceAngles.length > 0) {
        const sortedAutoplace = [...autoplaceAngles].sort((a, b) => b.score - a.score);

        for (let angle of sortedAutoplace) {
            if (this.placeAngles.length >= maxPlacements) break;

            // Check overlap with current placements
            const overlapsWithCurrent = this.placeAngles.some(placedAngle => {
                const dist = UTILS.getDistance(angle.x, angle.y, placedAngle.x, placedAngle.y);
                return dist <= angle.scale + placedAngle.scale;
            });

            // Check overlap with last preplace angles
            const overlapsWithLast = (this.lastPreplaceAngles || []).some(lastAngle => {
                const dist = UTILS.getDistance(angle.x, angle.y, lastAngle.x, lastAngle.y);
                return dist <= angle.scale + lastAngle.scale;
            });

            if (!overlapsWithCurrent && !overlapsWithLast) {
                this.placeAngles.push(angle);
            }
        }
    }
}

   getPrePlaceObjects() {
    const {myPlayer} = playerManager;
    const {nearestEnemy} = playerManager;
    
    let tmpObjects = objectManager.visibleObjects.filter(object => 
        object.health <= 300 && 
        UTILS.getDistance(object.x, object.y, myPlayer.x, myPlayer.y) <= 300
    );
    
    const predictedObjects = [];

    // Get objects for enemy (up to 2 closest)
    if(nearestEnemy) {
        const primary = nearestEnemy.weapons[0];
        const secondary = nearestEnemy.weapons[1];
        
        let weapon = null;
        let damage = 0;
        let reloadReady = false;
        
        if(secondary === 10) {
            weapon = secondary;
            damage = nearestEnemy.secondarySDamage;
            reloadReady = nearestEnemy.secondaryReload === 1 && nearestEnemy.lastSecondaryReload < 1;
        } else if(items.weapons[primary].speed <= 400) {
            weapon = primary;
            damage = nearestEnemy.primarySDamage;
            reloadReady = nearestEnemy.primaryReload === 1 && nearestEnemy.lastPrimaryReload < 1;
        }
        
        if(weapon) {
            const validObjects = tmpObjects.filter(object => {
                const distance = UTILS.getDistance(nearestEnemy.x, nearestEnemy.y, object.x, object.y);
                const inRange = distance <= (object.scale + items.weapons[weapon].range);
                const healthCheck = object.health <= damage;
                const hideCheck = !object.hideFromEnemy;
                
                return inRange && healthCheck && hideCheck;
            });
            
            validObjects.sort((a, b) => 
                UTILS.getDistance(a.x, a.y, nearestEnemy.x, nearestEnemy.y) - 
                UTILS.getDistance(b.x, b.y, nearestEnemy.x, nearestEnemy.y)
            );
            
            const closestTwo = validObjects.slice(0, 2);
            
            for(let obj of closestTwo) {
                obj.readyToPreplace = reloadReady; // TAG IT
                predictedObjects.push(obj);
                tmpObjects = tmpObjects.filter(o => o !== obj);
            }
        }
    }

    // Get objects for myPlayer
    if(autogather.state) {
        const {reload, dmg} = this.getMyPlayerReloadAndDamage(weapon.predictWeapon, myPlayer);
        
        const closestToPlayer = this.findClosestObject(
            tmpObjects,
            {x: myPlayer.x2, y: myPlayer.y2},
            weapon.predictWeapon,
            dmg,
            false,
            dir.predictDir
        );

        if(closestToPlayer) {
            closestToPlayer.readyToPreplace = reload === 1; // TAG IT
            predictedObjects.push(closestToPlayer);
        }
    }

    return predictedObjects;
}

    getEnemyWeaponAndDamage(enemy) {
        const primary = enemy.weapons[0];
        const secondary = enemy.weapons[1];

        if(secondary === 10 && enemy.secondaryReload === 1 && enemy.lastSecondaryReload < 1) {
            return {weapon: secondary, damage: enemy.secondarySDamage};
        } else if(items.weapons[primary].speed <= 400 && enemy.primaryReload === 1 && enemy.lastPrimaryReload < 1) {
            return {weapon: primary, damage: enemy.primarySDamage};
        }

        return {weapon: null, damage: 0};
    }

    getMyPlayerReloadAndDamage(predictWeapon, player) {
        if(predictWeapon < 9) {
            return {reload: player.primaryReload, dmg: player.primarySDamage};
        } else {
            return {reload: player.secondaryReload, dmg: player.secondarySDamage};
        }
    }

    findClosestObject(objects, target, weaponId, damage, isEnemyFilter, predictDir = null) {
        if(!weaponId) return null;

        const filtered = objects.filter(object => {
            const distance = UTILS.getDistance(target.x, target.y, object.x, object.y);
            const inRange = isEnemyFilter 
                ? distance <= (object.scale + items.weapons[weaponId].range)
                : (distance - object.scale) <= items.weapons[weaponId].range;

            const healthCheck = object.health <= damage;
            const hideCheck = isEnemyFilter ? !object.hideFromEnemy : true;

            if(!inRange || !healthCheck || !hideCheck) return false;

            // Angle check for player only
            if(!isEnemyFilter && predictDir !== null) {
                const angleOk = UTILS.getAngleDist(
                    UTILS.getDirection(object.x, object.y, target.x, target.y), 
                    predictDir
                ) <= config.gatherAngle;
                if(!angleOk) return false;
            }

            return true;
        });

        return filtered.sort((a, b) => 
            UTILS.getDistance(a.x, a.y, target.x, target.y) - 
            UTILS.getDistance(b.x, b.y, target.x, target.y)
        )[0];
    }

    getObjInInventory(checkId) {
        const {myPlayer} = playerManager;
        
        for(let i = 0; i < myPlayer.items.length; i++) {
            const itemId = items.list[myPlayer.items[i]].id;
            
            if([6, 7, 8, 9].includes(checkId) && itemId >= 6 && itemId <= 9) {
                return i;
            } else if(itemId === checkId) {
                return i;
            }
        }
        return null; 
    }

    getPredictObject(id, angle) {
        const {myPlayer} = playerManager;

        return {
            x: myPlayer.x + (35 + items.list[id].scale + (items.list[id].placeOffset || 0)) * Math.cos(angle),
            y: myPlayer.y + (35 + items.list[id].scale + (items.list[id].placeOffset || 0)) * Math.sin(angle),
            scale: items.list[id].scale,
        };
    }

    canPlace(id, angle, objects) {
        if(this.isItemLimit(id)) return false;

        const predictObject = this.getPredictObject(id, angle);
        return objectManager.checkItemLocation(predictObject.x, predictObject.y, predictObject.scale, 0.6, id, false, objects);
    }

    isItemLimit(id) {
        const {myPlayer} = playerManager;
        const group = items.list[id].group;
        const limit = group.sandboxLimit || 99;

        return myPlayer.itemCounts[group.id] >= limit;
    }
}

