            if(this.players[i].id != id) continue;

            this.players.splice(i, 1);
            break;
        }
    }

    addPlayer(data){
        const [playersData, isYou] = data;

        let tmpPlayer = this.findPlayerById(playersData[0]);
        if(!tmpPlayer){
            tmpPlayer = new Player();
            this.players.push(tmpPlayer);
        }

        tmpPlayer.visible = false;
        tmpPlayer.setData(playersData);
        tmpPlayer.spawn();

        if(isYou){
            this.myPlayer = tmpPlayer;
        }
    }

    updateProjectiles(){
        for(const projectile of projectileManager.projectiles){
            if(!projectile.isNew) continue;

            projectile.player = null;
            projectile.object = null;

            if(projectile.speed == 1.5){
                this.handleTurretProjectile(projectile);
            } else {
                this.handleWeaponProjectile(projectile);
            }
        }
    }

    handleTurretProjectile(projectile){
        projectile.weapon = "turret";
        
        let dist = 35;
        for(let player of this.players){
            if(player.visible && dist > UTILS.getDistance(player.x, player.y, projectile.x, projectile.y)){
                projectile.player = player;
                dist = UTILS.getDistance(player.x, player.y, projectile.x, projectile.y);
            }
        }

        if(projectile.player != null){
            projectile.player.turretReload = 0;
        } else {
            let dist = Infinity;
            for(let object of objectManager.objects){
                if(dist > UTILS.getDistance(object.x, object.y, projectile.x, projectile.y)){
                    projectile.object = object;
                    dist = UTILS.getDistance(object.x, object.y, projectile.x, projectile.y);
                }
            }
        }
    }

    handleWeaponProjectile(projectile){
        projectile.x2 = projectile.x - Math.cos(projectile.dir) * 70;
        projectile.y2 = projectile.y - Math.sin(projectile.dir) * 70;

        for(let i in items.projectiles){
            if(items.projectiles[i].range == projectile.range && items.projectiles[i].speed == projectile.speed){
                for(let weapon of items.weapons){
                    if(weapon.projectile == i){
                        projectile.weapon = weapon.id;
                    }
                }
            }
        }

        let dist = Infinity;
        for(let player of this.players){
            if(player.visible && UTILS.getDistance(player.x, player.y, projectile.x2, projectile.y2) < dist && player.weapons[1] == projectile.weapon){
                projectile.player = player;
                dist = UTILS.getDistance(player.x, player.y, projectile.x2, projectile.y2);
            }
        }

        if(projectile.player != null){
            if(projectile.player.skinIndex == 20){
                projectile.player.secondaryReload = .22;
            } else {
                projectile.player.secondaryReload = 0;
            }
        }
    }

    updateEnemies(){
        this.enemiesNear = [];
        for(let player of this.players){
            if(player.visible && player != this.myPlayer && (player.team == null || player.team != this.myPlayer.team)){
                this.enemiesNear.push(player);
            }
        }

        this.nearestEnemy = this.enemiesNear.sort((a, b) => UTILS.getDistance(this.myPlayer.x, this.myPlayer.y, a.x, a.y) - UTILS.getDistance(this.myPlayer.x, this.myPlayer.y, b.x, b.y))[0];
    }

    updateProjectileDamages() {
         if(projectileManager.removedProjectiles.length){
