        }
        ping();
        setInterval(ping, 1000);
    },
    "V": (data) => playerManager.updateItems(data),
    "I": (data) => aiManager.updateAIs(data[0]),
    "0": (data) => pingTracker.onPong(),
    "D": (data) => playerManager.addPlayer(data),
    "E": (data) => playerManager.removePlayer(data[0]),
    "A": (data) => game.setInitData(data[0]),
    "a": (data) => playerManager.loop(data[0]),
    "O": (data) => playerManager.updateHealth(data),
    "P": (data) => playerManager.killPlayer(),
    "Q": (data) => objectManager.killObject(data[0]),
    "R": (data) => objectManager.killObjects(data[0]),
    "H": (data) => spawnObjectsPacket.loadGameObjects(items, objectManager, data[0]),
    "X": (data) => projectileManager.add(data),
    "Y": (data) => projectileManager.remove(data),
    "5": (data) => playerManager.updateStoreItems(data),
    "N": (data) => playerManager.updatePlayerValue(data),
    "K": (data) => playerManager.gatherAnimation(data),
    "S": (data) => playerManager.updateItemCounts(data),
    "J": (data) => aiManager.animateAI(data),
    "7": (data) => playerManager.getMinimapData(data),
    "L": (data) => objectManager.wiggleObject(data[0], data[1]),
    "8": (data) => gameVisuals.showText(data),
    "6": (data) => playerManager.receiveChat(data[0], data[1]),
    "U": (data) => playerManager.updateUpgrades(data[0], data[1]),
    "4": (data) => playerManager.setAlliancePlayers(data[0])
};

WebSocket.prototype._send = WebSocket.prototype.send;
WebSocket.prototype.send = function(packet){
    client.init(this, events);

    packet = client.freeResources(packet);
    if(!client.shouldSend(packet)) return;

    this._send(client.stripModLabel(packet));
}
