            btn.className = "mini-btn";
            btn.onclick = onClick;
            return btn;
        };

        buttonContainer.appendChild(createMiniBtn("Find Empty", () => {
            let testServer = this.servers.filter(s => s.playerCount === 0).sort((a, b) => a.ping - b.ping)[0];
            if (testServer) window.location.href = `${location.protocol}//${location.hostname}/?server=${testServer.region}:${testServer.name}`;
        }));

        buttonContainer.appendChild(createMiniBtn("Find Active", () => {
            let activeServer = this.servers.sort((a, b) => (a.playerCount === b.playerCount ? a.ping - b.ping : b.playerCount - a.playerCount))[0];
            if (activeServer) window.location.href = `${location.protocol}//${location.hostname}/?server=${activeServer.region}:${activeServer.name}`;
        }));

        serverHeader.appendChild(sTitle);
        serverHeader.appendChild(buttonContainer);
        serverSection.appendChild(serverHeader);

