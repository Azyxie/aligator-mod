// ============================================================================
// MOD
// ============================================================================

class Mod {
    static features = [];
    static featuresByName = new Map();

    static register(feature){
        Mod.features.push(feature);
        Mod.featuresByName.set(feature.constructor.name, feature);
    }

    static getFeatures(){
        return Mod.features;
    }

    static getFeature(name){
        return Mod.featuresByName.get(name);
    }
}

class ModFeature {
    constructor(){
        Mod.register(this);
    }
}

class pollInput extends ModFeature {
    constructor() {
        super();
        this.element = null;
        this.mouseX = 0;
        this.mouseY = 0;
        this.leftClick = false;
        this.rightClick = false;
        this.usingTouch = false;
        this.lastWeaponButton = null;
        this.autoMillsPress = false;
        this.trapPlacePress = false;
        this.spikePlacePress = false;
        this.turretPlacePress = false;

        this.gameInput = this.gameInput.bind(this);
        this.mouseDown = this.mouseDown.bind(this);
        this.mouseUp = this.mouseUp.bind(this);
        this.preventContextMenu = this.preventContextMenu.bind(this);
        this.keyDown = this.keyDown.bind(this);
    }

    initialize(elementId = 'touch-controls-fullscreen') {
        this.element = document.getElementById(elementId);
        if (!this.element) {
            console.error(`Element with id '${elementId}' not found`);
            return;
        }

        this.attachListeners();
    }

    attachListeners() {
        this.element.addEventListener("mousemove", this.gameInput, false);
        this.element.addEventListener("mousedown", this.mouseDown, false);
        this.element.addEventListener("mouseup", this.mouseUp, false);
        this.element.addEventListener("contextmenu", this.preventContextMenu, false);
        window.addEventListener("keydown", this.keyDown, false);
        window.addEventListener("keyup", this.keyUp, false);
    }

    removeListeners() {
        if (!this.element) return;

        this.element.removeEventListener("mousemove", this.gameInput, false);
        this.element.removeEventListener("mousedown", this.mouseDown, false);
        this.element.removeEventListener("mouseup", this.mouseUp, false);
        this.element.removeEventListener("contextmenu", this.preventContextMenu, false);
        window.removeEventListener("keydown", this.keyDown, false);
        window.removeEventListener("keyup", this.keyUp, false);
    }

    keyUp(event){
        let keyStr = event.code;
        if (keyStr.startsWith("Key")) keyStr = keyStr.slice(3);
        if (keyStr.startsWith("Digit")) keyStr = keyStr.slice(5);
        keyStr = keyStr.toUpperCase();
        const keyNum = event.which || event.keyCode || 0;
        const {myPlayer} = playerManager;
        if(game.keys[keyNum]) game.keys[keyNum] = 0;
        if(myPlayer && myPlayer.alive && game.keysActive()){
            if(keyStr === settings.keyPlaceTrap) {
                this.trapPlacePress = false;
            } else if(keyStr === settings.keyPlaceSpike) {
                this.spikePlacePress = false;
            } else if(keyStr === settings.keyPlaceTurret) {
                this.turretPlacePress = false;
            }
        }
    }

    keyDown(event) {
        const keyNum = event.which || event.keyCode || 0;
        const {myPlayer} = playerManager;
        let keyStr = event.code;
        if (keyStr.startsWith("Key")) keyStr = keyStr.slice(3);
        if (keyStr.startsWith("Digit")) keyStr = keyStr.slice(5);
        keyStr = keyStr.toUpperCase();

        if(myPlayer && myPlayer.alive && game.keysActive()){
            if(!game.keys[keyNum]) game.keys[keyNum] = 1;
            if(keyNum == 69) game.ePress = !game.ePress;
            if (event.key === '1') {
                this.lastWeaponButton = 1;
            } else if (event.key === '2') {
                this.lastWeaponButton = 2;
            } else if(keyStr === settings.keyAutoMills) {
                this.autoMillsPress = !this.autoMillsPress;
            } else if(keyStr === settings.keyPlaceTrap) {
                this.trapPlacePress = true;
            } else if(keyStr === settings.keyPlaceSpike) {
                this.spikePlacePress = true;
            } else if(keyStr === settings.keyPlaceTurret) {
                this.turretPlacePress = true;
            } else if (keyNum == 88) {
                game.sendLockDir();
            }
        }
    }

    setUsingTouch(using) {
        this.usingTouch = using;
        this.updateGuide();
    }

    updateGuide() {
        const guideCard = document.getElementById('guideCard');
        if (guideCard) {
            if (this.usingTouch) {
                guideCard.classList.add("touch");
            } else {
                guideCard.classList.remove("touch");
            }
        }
    }

    gameInput(e) {
        e.preventDefault();
        e.stopPropagation();

        this.setUsingTouch(false);
        this.mouseX = e.clientX;
        this.mouseY = e.clientY;

        window.mouseX = this.mouseX;
        window.mouseY = this.mouseY;
    }

    mouseDown(e) {
        e.preventDefault();
        this.setUsingTouch(false);

        if (e.button === 0) {
            this.leftClick = true;
        } else if (e.button === 2) {
            this.rightClick = true;
        }
    }

    mouseUp(e) {
        e.preventDefault();
        this.setUsingTouch(false);

        if (e.button === 0) {
            this.leftClick = false;
        } else if (e.button === 2) {
            this.rightClick = false;
        }
    }

    preventContextMenu(e) {
        e.preventDefault();
    }

    getMousePosition() {
        return { x: this.mouseX, y: this.mouseY };
    }

    destroy() {
        this.removeListeners();
        this.element = null;
    }
}

class ObjectDamageManager {
    constructor(items, config, UTILS){
        this.items = items;
        this.config = config;
        this.UTILS = UTILS;

        this.damageObjects = [];
        this.objectHits = [];
        this.objectShoots = [];
    }

    changeObjectHealth(p, w, objs){
        const {weapons} = this.items;
        let dmg = weapons[w].dmg * (weapons[w].sDmg || 1) * (p.skinIndex == 40 ? 3.3 : 1) * this.config.weaponVariants[p.weaponVariants[w]].val;
        for (let o of objs) o.health -= dmg;
    }

    checkBuildingDamage(proj, objs){
        let end = {x: proj.x + proj.range * Math.cos(proj.dir), y: proj.y + proj.range * Math.sin(proj.dir)};
        for (let o of objs) {
            if (!o.ignoreCollision && this.UTILS.lineInRect(o.x - o.scale, o.y - o.scale, o.x + o.scale, o.y + o.scale, proj.x, proj.y, end.x, end.y)) {
                if (o.id == 3) o.health -= proj.dmg;
            }
        }
    }

    addShoot(projectile){
        const parent = this;
        this.objectShoots.push({objects: parent.damageObjects, projectile: projectile});

        this.damageObjects = [];
    }

    addHit(player, weapon){
        const parent = this;
        this.objectHits.push({objects: parent.damageObjects, player: player, weapon: weapon});

        this.damageObjects = [];
    }

    update(){
        if(this.objectShoots.length) for (let s of this.objectShoots) this.checkBuildingDamage(s.projectile, s.objects);
        if(this.objectHits.length) for (let h of this.objectHits) this.changeObjectHealth(h.player, h.weapon, h.objects);

        this.objectShoots = [];
        this.objectHits = [];
        this.damageObjects = [];
    }
}

