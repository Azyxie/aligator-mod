class SpawnObjectsPacket {
    wait(){
        let waitResolve = null;
        const promise = new Promise(function(resolve, reject){
            waitResolve = resolve;
            setTimeout(function(){
                waitResolve([]);
            }, 1);
        });

        this.waitResolve = waitResolve;
        return promise.then(function(sids){
            return sids;
        });
    }

    loadGameObjects(items, objectManager, data){
        let sids = [];
        for(let i = 0;i < data.length;i += 8){
            objectManager.add(data[i], data[i + 1], data[i + 2], data[i + 3], data[i + 4], data[i + 5], items.list[data[i + 6]], true, (data[i + 7] >= 0 ? {sid: data[i + 7]} : null));
            sids.push(data[i]);
        }

        if(this.waitResolve != null){
            this.waitResolve(sids);
        }
    }
}

