    updatePlayers(data, tmpTime){
        for(let i = 0;i < this.players.length;i++){
            this.players[i].forcePos = !this.players[i].visible;
            this.players[i].visible = false;
        }

        for(let i = 0; i < data.length;){
            const tmpObj = this.findPlayerBySid(data[i]);
            if (tmpObj) {
                tmpObj.updatePosition(data[i + 1], data[i + 2]);

                tmpObj.lastTime = (tmpObj.time == undefined ? tmpTime : tmpObj.time);
                tmpObj.time = tmpTime;

                tmpObj.lastDir = (tmpObj.dir == undefined ? data[i + 3] : tmpObj.dir);
                tmpObj.dir = data[i + 3];

                tmpObj.lastXRender = tmpObj.xRender;
                tmpObj.lastYRender = tmpObj.yRender;

                tmpObj.updateTime = 0;

                tmpObj.buildIndex = data[i + 4];
                tmpObj.weaponIndex = data[i + 5];
                tmpObj.weaponVariant = data[i + 6];

                tmpObj.team = data[i + 7];
                tmpObj.isLeader = data[i + 8];

                tmpObj.lastSkinIndex = tmpObj.skinIndex;
                tmpObj.lastTailIndex = tmpObj.tailIndex;

                tmpObj.skinIndex = data[i + 9];
                tmpObj.tailIndex = data[i + 10];

                tmpObj.iconIndex = data[i + 11];
                tmpObj.zIndex = data[i + 12];

                tmpObj.visible = true;

                tmpObj.lastTickParams = tmpObj.tickParams;
                this.updateWeapons(tmpObj);
                this.updateDamages(tmpObj);

                tmpObj.predictPrimaryHit = false;
                tmpObj.predictSecondaryHit = false;
                tmpObj.predictTurretHit = false;
            }

            i += 13;
        }
    }

    updateDamages(player) {
        const primary = player.weapons[0];
        const secondary = player.weapons[1];
        let bullDmg = 1.5;
        if(player.tailIndex == 11) {
            bullDmg = 1;
        }
        const tankDmg = 3.3;
        if(primary) {
            
            const base = items.weapons[primary].dmg;
            const variantConfig = config.weaponVariants[player.weaponVariants?.[primary]];
            const variant = variantConfig?.val || 1;
            player.primaryDamage = base * bullDmg * variant;
            player.primarySDamage = base * tankDmg * variant;
        }
       if(secondary) {
            const weapon = items.weapons[secondary];
            const base = weapon.projectile !== undefined 
                ? (items.projectiles[weapon.projectile]?.dmg || 0)
                : (weapon.dmg || 0);
            
            const variantConfig = config.weaponVariants[player.weaponVariants?.[secondary]];
            const variant = variantConfig?.val || 1;
            
            if(secondary == 10) {
                player.secondaryDamage = base * bullDmg * variant;
                player.secondarySDamage = base * tankDmg * variant * 7.5;
            } else {
                player.secondaryDamage = base;
                player.secondarySDamage = 0;
            }
        }
    }

    updateWeapons(player) {
        if (player.buildIndex >= 0) return;
        
        const isPrimary = player.weaponIndex < 9;
        const slot = isPrimary ? 0 : 1;
        const isMyPlayer = player == this.myPlayer;
        
        if (!isMyPlayer) player.weapons[slot] = player.weaponIndex;
        player.weaponVariants[player.weaponIndex] = player.weaponVariant;

        player.lastPrimaryReload = player.primaryReload;
        player.lastSecondaryReload = player.secondaryReload;
        
        const reloadKey = slot ? 'secondaryReload' : 'primaryReload';
        player[reloadKey] = Math.min(1, (player[reloadKey] || 0) + 
            config.tickRate / items.weapons[player.weaponIndex].speed);
        
         if (!isMyPlayer) {
            // Set default primary first
            if(player.weapons[0] == undefined) {
                player.weapons[0] = 5;
                player.weaponVariants[player.weapons[0]] = 2;
                player.primaryReload = 1;
            }

            // Then set default secondary based on primary
            if(player.weapons[0] != 0 && player.weapons[1] == undefined) {
                const usesMusket = player.weapons[0] == 5 || player.weapons[0] == 3;
                player.weapons[1] = usesMusket ? 15 : 10;
                if (!usesMusket) player.weaponVariants[player.weapons[1]] = 2;
                player.secondaryReload = 1;
            }
        }
        
        player.turretReload = Math.min(1, (player.turretReload || 0) + config.tickRate / 2500);
        
        if (isMyPlayer && !player.weapons[1]) {
            player.secondaryReload = 1;
            player.weaponVariants[player.weapons[1]] = 0;
        }
        if(isMyPlayer && player.weapons[0] == undefined) player.weapons[0] = 0;
    }

    updateHits() {
        if (!this.hits.length) return;
        
        for (let {player, weapon} of this.hits) {
            const isPrimary = weapon < 9;
            const reloadKey = isPrimary ? 'primaryReload' : 'secondaryReload';
            const reloadValue = player.skinIndex == 20 && (isPrimary ? items.weapons[weapon].speed > 300 : true) ? .22 : 0;
            player[reloadKey] = reloadValue;
            if(player == this.myPlayer) {
                distribuitionDamages.update({type: "enemyhats", weapon: weapon});
            } else {
                if(!this.myPlayer.isAlly(player.sid)) {
                    distribuitionDamages.update({type: "hit", weapon: weapon, player: player});
                }
            }
        }
        
        this.hits = [];
    }
}

