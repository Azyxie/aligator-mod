        this.predictAcc = 0;
        this.autoBuyList = [ // (order-wise)
            { id: 15, type: 0, cost: 600 }, // winter
            { id: 11, type: 1, cost: 2000 }, // monkey_tail
            { id: 31, type: 0, cost: 2500 }, // flipper
            { id: 6, type: 0, cost: 4000 }, // soldier
            { id: 40, type: 0, cost: 15000 }, // tank
            { id: 7, type: 0, cost: 6000 }, // bull
            { id: 22, type: 0, cost: 6000 }, // emp
            { id: 12, type: 0, cost: 6000 }, // booster
            { id: 53, type: 0, cost: 10000 }, // turret
            { id: 19, type: 1, cost: 15000 } // shadow_wings
        ];
        this.safeSoldier = false;
    }

    isBought(id, isAcc) {
        const {myPlayer} = playerManager;
        if(!myPlayer) return false;
        if(isAcc){
            return myPlayer.tails[id];
        } else {
            return myPlayer.skins[id];
        }
    }

    updateAcc(id) {
        if(this.isBought(id, 1)) {
            this.predictAcc = id;
        }
    }

    updateHat(id) {
        if(this.isBought(id, 0)) {
            this.predictHat = id;
        }
    }
 
    autoBuy() {
        if (settings.autoBuy) {
            for (const item of this.autoBuyList) {
                if (!this.isBought(item.id, item.type)) {
                    const { myPlayer } = playerManager;
                    if (myPlayer && myPlayer.points >= item.cost) {
                        game.storeBuy(item.id, item.type);
                    }
                    break;
                }
            }
        }
    }

    shameBullEquip() {
        const {myPlayer} = playerManager;
        if(myPlayer.shameCount < 1) return;
        if(damage.poisonCount > 0) return;
        if(damage.collidingSpike) return;
        if (damage.willPoison) {
            this.updateHat(7);
        }

    }

    DefaultPriorityAcc() {
        const {myPlayer} = playerManager;
        const {nearestEnemy} = playerManager;
        
        if(nearestEnemy && UTILS.getDistance(myPlayer.x, myPlayer.y, nearestEnemy.x, nearestEnemy.y) < 300) {
            this.updateAcc(0); // No tail
            this.updateAcc(19); // Shadow wings
        } else {
            this.updateAcc(11); // Monkey tail
        }
    }

    DefaultPriorityHat() {
        const {myPlayer} = playerManager;
        const {nearestEnemy} = playerManager;
        this.safeSoldier = false;
        
        this.updateHat(6); // Default soldier 
        this.updateHat(12); // Default booster
        if(myPlayer.y < 2400) this.updateHat(15); // Winter hat
        if(myPlayer.y > 6838 && myPlayer.y < 7562) this.updateHat(31); // Fish hat
        if(nearestEnemy && UTILS.getDistance(myPlayer.x, myPlayer.y, nearestEnemy.x, nearestEnemy.y) < 300) {
            this.updateHat(6); // Soldier
            if(myPlayer.y > 6838 && myPlayer.y < 7562) this.updateHat(31); // Fish hat
        }
        if(move.predictAngle == null) this.updateHat(6);
    }

    soldierAntiHat() {
        if(damage.predictTotal >= 100) {
            this.updateHat(6);
            this.safeSoldier = true;
        }
    }

    gatherPriorityHat() {
        const {myPlayer} = playerManager;
        const {nearestEnemy} = playerManager;
        if(!autogather.state) return;
        if(weapon.predictWeapon < 9 && myPlayer.primaryReload == 1) {
            if(nearestEnemy && UTILS.getDistance(myPlayer.x, myPlayer.y, nearestEnemy.x, nearestEnemy.y) < 35 * 1.8 + items.weapons[weapon.predictWeapon].range) {
                this.updateHat(7);
            } else {
                this.updateHat(40);
            }
        } else if(weapon.predictWeapon > 8 && myPlayer.secondaryReload == 1) {
            this.updateHat(40);
        }
        if(autobreak.state) {
            if(autobreak.weapon > 8 && myPlayer.secondaryReload == 1) {
                this.updateHat(40);
            } else if(autobreak.weapon < 9 && myPlayer.primaryReload == 1) {
                this.updateHat(40);
            }
        }
        if(combat.state) {
            this.updateHat(combat.hat);
        }
    }
    

    send() {
        const {myPlayer} = playerManager;
          if(myPlayer.skinIndex != this.predictHat){
            game.equipHat(this.predictHat, 0);
        } else {
            if(myPlayer.tailIndex != this.predictAcc){
                game.equipAcc(this.predictAcc, 0);
            }
        }
    }
}

class Damage {
    constructor() {
        this.predict = [];
        this.poisonTick = 0;
        this.willPoison = false;
        this.poisonCount = 0; 
        this.predictTotal = 0;
        this.reductedDmg = false;
        this.collidingSpike = false;
        this.lastCollidingSpike = false;
    }

    reset() {
        this.predict = [];
    }

    // ==================== POISON SYSTEM ====================
    
    getPoisonTick() {
        const {myPlayer} = playerManager;
        this.willPoison = false;
        
        const poisonDamages = distribuitionDamages.distributedDamages.filter(dmg => dmg.type === "poison");

        // Reset poison tracking if too old
        if((tickManager.count - this.poisonTick) > 15) {
            this.poisonTick = 0;
        }
        
        // Update poison tick on new poison damage
        if(poisonDamages.length > 0) {
            this.poisonTick = tickManager.count;
            if(this.poisonCount > 0) {
                this.poisonCount--;
            }
        }
        
        // Calculate if poison will hit next tick
        if(this.poisonTick > 0) {
            const ticksSincePoison = tickManager.count - this.poisonTick;
            const nextPoisonIn = 9 - (ticksSincePoison % 9);
            const nextnextPoisonIn = 10 - (ticksSincePoison % 10);
            
            if(nextPoisonIn === 1 || nextnextPoisonIn === 1) {
                this.willPoison = true;
            }
        } else {
            this.willPoison = true; // Assume poison possible if no tracking
        }
        
        // Reset on death
        if(!myPlayer.alive) {
            this.poisonCount = 0;
            this.poisonTick = 0;
        }
    }

    checkRubyHit() {
        const hits = distribuitionDamages.distributedDamages.filter(dmg => dmg.type === "hit");
        for(const hit of hits) {
            const weapon = hit.weapon;
            const player = hit.player;
            if(player.weaponVariants[weapon] === 3) { // Ruby variant
                this.poisonCount = 5; 
            }
        }
    }

    checkPoisonSpikes() {
        const spikeDamages = distribuitionDamages.distributedDamages.filter(
            dmg => dmg.type === "spikes" && dmg.spikeType === "poison"
        );
        if(spikeDamages.length > 0) {
            this.poisonCount = 5;
        }
    }

    predictPoison() {
        if(this.poisonCount > 0 && this.willPoison) {
            this.predict.push({ type: "poison", dmg: 5 });
        }
    }

    predictBullPoison() {
        if(cosmetics.predictHat === 7 && this.willPoison) {
            this.predict.push({ type: "poison", dmg: 5 });
        }
    }

    // ==================== SPIKE PREDICTIONS ====================

    predictCollisionDmg() {
        const {myPlayer} = playerManager;
        this.lastCollidingSpike = this.collidingSpike;
        this.collidingSpike = false;
        
        if(!myPlayer.trap) return;

        const closeSpikes = objectManager.visibleObjects.filter(obj => 
            objectManager.isEnemyObject(myPlayer, obj) && 
            objectManager.isSpike(obj) && 
            UTILS.getDistance(myPlayer.x, myPlayer.y, obj.x, obj.y) < 92
        );
        
        if(closeSpikes.length === 0) return;

        const spikeDamages = distribuitionDamages.distributedDamages.filter(spike => spike.type === "spikes");
        
        for(const damageSpike of spikeDamages) {
            for(const spike of closeSpikes) {
                let dmg = damageSpike.damage;
                
                // Normalize damage if soldier helmet was equipped
                if(!(dmg === 20 || dmg === 30 || dmg === 35 || dmg === 45)) {
                    dmg /= 0.75;
                }
                
                if(this.damagesMatch(spike.dmg, dmg, 1)) {
                    this.predict.push({ type: "spikes", dmg: spike.dmg });
                    this.collidingSpike = true;
                    break;
                }
            }
        }
    }

    predictCollisionHits() {
        const {myPlayer} = playerManager;
        if(!this.collidingSpike) return;

        for(const enemy of playerManager.enemiesNear) {
            const shouldPredict = 
                !this.lastCollidingSpike || 
                (enemy.lastPrimaryReload < 1 && enemy.primaryReload === 1) ||
                (myPlayer.weapons[1] === 10 && myPlayer.secondaryReload === 1 && myPlayer.lastSecondaryReload < 1);

            if(shouldPredict) {
                this.addEnemyHit(enemy);
            }
        }
    }

    predictVelSpikes(spikeDmg = 0, spikes) {
        const {myPlayer} = playerManager;
        
        if(this.collidingSpike || myPlayer.lastTrap) return;

        const KNOCKBACK_RANGE_PREDICT = 100;
        const KNOCKBACK_RANGE_ACTUAL = 120;
        let found = false;

        const getCloseSpikes = (range, useX2 = true) => {
            const totSpikes = objectManager.visibleObjects.filter(obj => 
                objectManager.isSpike(obj) && objectManager.isEnemyObject(myPlayer, obj)
            );
            
            return totSpikes.filter(spike => {
                const x = useX2 ? myPlayer.x2 : myPlayer.x;
                const y = useX2 ? myPlayer.y2 : myPlayer.y;
                return UTILS.getDistance(spike.x, spike.y, x, y) <= range;
            });
        };

        // Predicted spike hit from velocity calculation
        if(spikeDmg > 0) {
            this.predict.push({ type: "spikes", dmg: spikeDmg });
            
            // Predict knockback into more spikes
            if(spikeDmg < 100) {
                const closeSpikes = getCloseSpikes(KNOCKBACK_RANGE_PREDICT, true);
                for(const spike of closeSpikes) {
                    this.predict.push({ type: "spikes", dmg: spike.dmg });
                    found = true;
                }
            }
        } 
        // Actual spike damage from server
        else {
            const spikeDamages = distribuitionDamages.distributedDamages.filter(dmg => dmg.type === "spikes");
            
            if(spikeDamages.length > 0) {
                const closeSpikes = getCloseSpikes(KNOCKBACK_RANGE_ACTUAL, false);
                for(const spike of closeSpikes) {
                    this.predict.push({ type: "spikes", dmg: spike.dmg });
                    found = true;
                }
            }
        }

        // Add enemy hits if we found spikes
        if(found) {
            for(const enemy of playerManager.enemiesNear) {
                this.addEnemyHit(enemy);
            }
        }
    }

    predictSpikeTick() {
        const {myPlayer} = playerManager;
        if(this.collidingSpike) return;

        const SPIKE_ID = 9;
        const SPIKE_POSITIONS = 36;
        const MAX_ENEMY_DISTANCE = 250;

        for(const enemy of playerManager.enemiesNear) {
            if(UTILS.getDistance(enemy.x2, enemy.y2, myPlayer.x2, myPlayer.y2) > MAX_ENEMY_DISTANCE) {
                continue; // Fixed: was return
            }

            for(let i = 0; i < SPIKE_POSITIONS; i++) {
                const angle = UTILS.toRad(i * (360 / SPIKE_POSITIONS));
                const offset = 35 + items.list[SPIKE_ID].scale + (items.list[SPIKE_ID].placeOffset || 0);
                
                const config = {
                    x: enemy.x + offset * Math.cos(angle),
                    y: enemy.y + offset * Math.sin(angle),
                    x2: enemy.x2 + offset * Math.cos(angle),
                    y2: enemy.y2 + offset * Math.sin(angle),
                    scale: items.list[SPIKE_ID].scale
                };

                if(!objectManager.checkItemLocation(config.x2, config.y2, config.scale, 0.6, SPIKE_ID, false, objectManager.visibleObjects)) {
                    continue;
                }

                if(UTILS.getDistance(config.x2, config.y2, myPlayer.x2, myPlayer.y2) <= 35 + config.scale) {
                    this.predict.push({ type: "spike", dmg: 45 });
                    
                    if(!myPlayer.trap && myPlayer.lastTrap) {
                        this.addEnemyHit(enemy);
                    }
                    break;
                }
            }
        }
    }

    // ==================== KNOCKBACK PREDICTIONS ====================

    knockbackPredict() {
        const {myPlayer} = playerManager;
        if(myPlayer.trap) return;

        for(const enemy of playerManager.enemiesNear) {
            // Try with primary weapon
            playerPosition.update(dir.predictDir, config.tickRate, myPlayer, enemy, "kbAnti", true);
            if(myPlayer.predictKbDmg > 0) {
                this.predict.push({ type: "spikes", dmg: myPlayer.predictKbDmg });
                this.addEnemyHit(enemy);
                return;
            }

            // Try with secondary weapon
            playerPosition.update(dir.predictDir, config.tickRate, myPlayer, enemy, "kbAnti", false);
            if(myPlayer.predictKbDmg > 0) {
                this.predict.push({ type: "spikes", dmg: myPlayer.predictKbDmg });
                this.addEnemyHit(enemy);
                return;
            }
        }
    }

    autopushPredict() {
        const {myPlayer} = playerManager;
        if(!myPlayer.trap) return;

        if(myPlayer.predictSpikeDamage > 0) {
            this.predict.push({ type: "spikes", dmg: myPlayer.predictSpikeDamage });
            for(const enemy of playerManager.enemiesNear) {
                this.addEnemyHit(enemy);
            }
        }
    }

    // ==================== ENEMY ATTACK PREDICTIONS ====================

    addEnemyHit(enemy, type) {
        const {myPlayer} = playerManager;

        if(type === "secondary") {
            if(enemy.secondaryReload < 1 || enemy.predictSecondaryHit || enemy.predictPrimaryHit) return;
            
            const distance = 35 * 1.8 + (items.weapons[enemy.weapons[1]].range || 300);
            if(UTILS.getDistance(myPlayer.x2, myPlayer.y2, enemy.x2, enemy.y2) > distance) return;
            
            this.predict.push({ type: "secondary hit", dmg: enemy.secondaryDamage });
            enemy.predictSecondaryHit = true;
        } 
        else if(type === "turret") {
            if(enemy.turretReload < 1 || enemy.predictTurretHit || enemy.predictPrimaryHit || enemy.predictSecondaryHit) return;
            if(UTILS.getDistance(myPlayer.x2, myPlayer.y2, enemy.x2, enemy.y2) > 200) return;
            
            this.predict.push({ type: "turret hit", dmg: 25 });
            enemy.predictTurretHit = true;
        } 
        else if(type === "instakill") {
            if(enemy.predictPrimaryHit) return;

            if(items.weapons[enemy.weapons[1]].projectile) {
                if(enemy.secondaryReload === 1 && !enemy.predictSecondaryHit) {
                    this.predict.push({ type: "secondary hit", dmg: enemy.secondaryDamage });
                    enemy.predictSecondaryHit = true;
                }
                if(enemy.turretReload === 1 && !enemy.predictTurretHit) {
                    this.predict.push({ type: "turret", dmg: 25 });
                    enemy.predictTurretHit = true;
                }
            } 
            else if(enemy.weapons[1] === 10) {
                if(!enemy.predictSecondaryHit) {
                    const distance = 35 * 1.8 + (items.weapons[enemy.weapons[1]].range || 300);
                    if(enemy.secondaryReload === 1 && UTILS.getDistance(myPlayer.x2, myPlayer.y2, enemy.x2, enemy.y2) < distance) {
                        this.predict.push({ type: "secondary hit", dmg: enemy.secondaryDamage });
                        enemy.predictSecondaryHit = true;
                    }
                }
                if(enemy.turretReload === 1 && !enemy.predictTurretHit) {
                    this.predict.push({ type: "turret", dmg: 25 });
                    enemy.predictTurretHit = true;
                }
            }
        } 
        else {
            // Primary weapon
            if(enemy.primaryReload < 1 || enemy.predictPrimaryHit) return;
            
            const distance = 35 * 1.8 + items.weapons[enemy.weapons[0]].range;
            if(UTILS.getDistance(myPlayer.x2, myPlayer.y2, enemy.x2, enemy.y2) > distance) return;
            
            this.predict.push({ type: "primary hit", dmg: enemy.primaryDamage });
            enemy.predictPrimaryHit = true;
        }
    }

    predictAutosteal() {
        const {myPlayer} = playerManager;
        if(this.collidingSpike) return;

        for(const enemy of playerManager.enemiesNear) {
            if(myPlayer.health <= 25) {
                this.addEnemyHit(enemy, "turret");
            }
            if(enemy.primaryDamage >= myPlayer.health) {
                this.addEnemyHit(enemy);
            }
        }
    }

    predictInstakill() {
        const hits = distribuitionDamages.distributedDamages.filter(hit => hit.type === "hit");
        for(const entity of hits) {
            this.addEnemyHit(entity.player, "instakill");
        }
    }

    predictProjectilesDmg() {
        const {myPlayer} = playerManager;

        for(const projectile of projectileManager.projectiles) {
            if(!projectile.active) continue;

            const isAlly = this.isProjectileAlly(projectile, myPlayer);
            if(isAlly) continue;

            const willHit = UTILS.lineInRect(
                myPlayer.x2 - myPlayer.scale,
                myPlayer.y2 - myPlayer.scale,
                myPlayer.x2 + myPlayer.scale,
                myPlayer.y2 + myPlayer.scale,
                projectile.x, projectile.y, 
                projectile.xVel, projectile.yVel
            );

            if(willHit) {
                if(projectile.weapon === "turret") {
                    for(const enemy of playerManager.enemiesNear) {
                        this.addEnemyHit(enemy);
                    }
                }
                this.predict.push({ type: "projectile", projectile: projectile, dmg: projectile.dmg });
            }
        }
    }

    isProjectileAlly(projectile, myPlayer) {
        if(projectile.player != null) {
            return myPlayer.alive && myPlayer.isAlly(projectile.player.sid);
        }
        if(projectile.object != null && projectile.object.owner) {
            return myPlayer.isAlly(projectile.object.owner.sid);
        }
        return false;
    }

    // ==================== ENEMY HAT PREDICTIONS ====================

    predictEnemyHats() {
        const {myPlayer} = playerManager;
        if(!autogather.state) return;

        const weap = weapon.predictWeapon;
        
        // Check if weapon is ready
        if(weap > 8) {
            if(myPlayer.secondaryReload < 1) return;
        } else {
            if(myPlayer.primaryReload < 1) return;
        }

        const baseDmg = items.weapons[weap].dmg * 
                       (shop.getHat(cosmetics.predictHat).dmgMultO || 1) * 
                       config.weaponVariants[myPlayer.weaponVariants[weap]].val;

        for(const enemy of playerManager.enemiesNear) {
            if(!this.isEnemyInRange(enemy, weap, myPlayer)) continue;
            if(!this.isEnemyInAngle(enemy, myPlayer)) continue;

            this.addEnemyHatDamage(enemy, baseDmg);
        }
    }

    isEnemyInRange(enemy, weap, myPlayer) {
        const distance = 35 * 1.8 + (items.weapons[weap].range || 300);
        return UTILS.getDistance(myPlayer.x2, myPlayer.y2, enemy.x2, enemy.y2) <= distance;
    }

    isEnemyInAngle(enemy, myPlayer) {
        const gatherAngle = dir.predictAngle;
        const angleToEnemy = UTILS.getDirection(enemy.x2, enemy.y2, myPlayer.x2, myPlayer.y2);
        let angleDiff = gatherAngle - angleToEnemy;
        angleDiff = Math.atan2(Math.sin(angleDiff), Math.cos(angleDiff));
        return Math.abs(angleDiff) <= config.hitAngle;
    }

    addEnemyHatDamage(enemy, baseDmg) {
        const HAT_SAWBLADE = 16;
        const HAT_CX_WINGS = 21;
        const HAT_SPIKE = 11;

        if(enemy.tailIndex === HAT_SAWBLADE) {
            this.predict.push({ type: "sawblade", dmg: baseDmg * 0.15 });
        }
        if(enemy.tailIndex === HAT_CX_WINGS) {
            this.predict.push({ type: "cx wings", dmg: baseDmg * 0.25 });
        }
        if(enemy.skinIndex === HAT_SPIKE) {
            this.predict.push({ type: "spike hat", dmg: baseDmg * 0.45 });
        }
    }

    // ==================== TOTAL DAMAGE & REDUCTION ====================

    getTotal() {
        this.predictTotal = 0;
        this.reductedDmg = false;

        for(const object of this.predict) {
            this.predictTotal += object.dmg;
        }

        // Cap at max damage
        if(this.predictTotal > 135) {
            this.predictTotal = 135;
        }

        // Apply soldier helmet reduction
        if(cosmetics.predictHat === 6) {
            this.predictTotal *= 0.75;
            this.reductedDmg = true;
        }
    }

    totalReduction() {
        if(this.reductedDmg) return;
        
        if(cosmetics.predictHat === 6) {
            this.predictTotal *= 0.75;
            this.reductedDmg = true;
        }
    }

    // ==================== UTILITIES ====================

    damagesMatch(damage1, damage2, threshold = 0.3) {
        return Math.abs(damage1 - damage2) < threshold;
    }
}

class PlayerPosition {
    update(moveDir, delta, player, enemy, type, futurePos) {
        if (!player) return;

        this.x = player.x;
        this.y = player.y;

        let predictKb = false;

       const isMyPlayer = playerManager.myPlayer === player;

        this.skin = shop.getHat(isMyPlayer ? cosmetics.predictHat : player.skinIndex);
        this.tail = shop.getAcc(isMyPlayer ? cosmetics.predictAcc : player.tailIndex);

        this.slowMult = player.lastTickParams?.slowMult ?? 1;

        // SLOW MULT
        if (this.slowMult < 1) {
            this.slowMult = Math.min(1, this.slowMult + 0.0008 * delta);
        }

        // BASE VELOCITY
        if (player.trap) {
            this.xVel = 0;
            this.yVel = 0;
        } else {
            this.xVel = player.lastTickParams?.x ?? 0;
            this.yVel = player.lastTickParams?.y ?? 0;

            let spdMult = 1;
            spdMult *= items.weapons[isMyPlayer ? weapon.predictWeapon : player.weaponIndex]?.spdMult || 1;
            spdMult *= this.skin?.spdMult || 1;
            spdMult *= this.tail?.spdMult || 1;
            spdMult *= this.y <= config.snowBiomeTop ? (this.skin?.coldM ? 1 : config.snowSpeed) : 1;

            // RIVER
            const riverHalf = config.riverWidth / 2;
            const mapMid = config.mapScale / 2;
            if (this.y >= mapMid - riverHalf && this.y <= mapMid + riverHalf) {
                if (this.skin?.watrImm) {
                    spdMult *= 0.75;
                    this.xVel += config.waterCurrent * 0.4 * delta;
                } else {
                    spdMult *= 0.33;
                    this.xVel += config.waterCurrent * delta;
                }
            }

            // MOVE DIRECTION
            if (moveDir != null) {
                const cos = Math.cos(moveDir);
                const sin = Math.sin(moveDir);
                const len = Math.sqrt(cos * cos + sin * sin);
                const speed = config.playerSpeed * spdMult * delta;

                if (len !== 0) {
                    this.xVel += (cos / len) * speed;
                    this.yVel += (sin / len) * speed;
                }
            }
        }

    if(type == "kbAnti" && enemy.weapons[0]) {
        const distance = 35 * 1.8 + (items.weapons[enemy.weapons[0]].range);
        if(futurePos && UTILS.getDistance(enemy.x2, enemy.y2, player.x2, player.y2) > distance) return;
        if(!futurePos && UTILS.getDistance(enemy.x, enemy.y, player.x2, player.y2) > distance) return;
        if(enemy.primaryReload < 1) return;
        let dir = 0;
        if(futurePos) {
            dir = UTILS.getDirection(this.x, this.y, enemy.x2, enemy.y2);
        } else {
            dir = UTILS.getDirection(this.x, this.y, enemy.x, enemy.y);
        }
        const spd = 0.3 + (items.weapons[enemy.weapons[0]].knock || 0);
        this.xVel += spd * Math.cos(dir);
        this.yVel += spd * Math.sin(dir); 
        predictKb = true;
    } 

    // MOVEMENT + COLLISION
    const tmpSpeed = UTILS.getDistance(0, 0, this.xVel * delta, this.yVel * delta);
    const depth = Math.min(4, Math.max(1, Math.round(tmpSpeed / 40)));
    const tMlt = 1 / depth;
    const playerScale = player.scale;
    const playerSid = player.sid;

    for (let i = 0; i < depth; i++) {
        if (this.xVel) this.x += (this.xVel * delta) * tMlt;
        if (this.yVel) this.y += (this.yVel * delta) * tMlt;

        const sorted = objectManager.visibleObjects.slice().sort((a, b) => {
            const distA = (this.x - a.x) ** 2 + (this.y - a.y) ** 2;
            const distB = (this.x - b.x) ** 2 + (this.y - b.y) ** 2;
            return distA - distB;
        });

        for (const object of sorted) {
            if (object.ignoreCollision) continue;

            const dx = this.x - object.x;
            const dy = this.y - object.y;
            const broadPhase = playerScale + object.scale; 

            if (Math.abs(dx) > broadPhase && Math.abs(dy) > broadPhase) continue;  

            const objScale = object.getScale ? object.getScale() : object.scale;
            const combinedScale = playerScale + objScale;
            const dist = Math.sqrt(dx * dx + dy * dy) - combinedScale;

            if (dist > 0) continue;

            const dir = UTILS.getDirection(this.x, this.y, object.x, object.y);
            const cosDir = Math.cos(dir);
            const sinDir = Math.sin(dir);

            this.x = object.x + combinedScale * cosDir;
            this.y = object.y + combinedScale * sinDir;
            this.xVel *= 0.75;
            this.yVel *= 0.75;

            if (object.dmg && object.owner.sid !== playerSid && !player.isAlly(object.owner.sid)) {
                const tmpSpd = 1.5 * (object.weightM || 1);  
                this.xVel += tmpSpd * cosDir;
                this.yVel += tmpSpd * sinDir;
                if(predictKb && type == "kbAnti")
                    player.predictKbDmg += 45;
            } else if (object.type === 1 && object.y >= config.mapScale - config.snowBiomeTop) {
                const tmpSpd = 1.5 * (object.weightM || 1); 
                this.xVel += tmpSpd * cosDir;
                this.yVel += tmpSpd * sinDir;
                if(predictKb && type == "kbAnti")
                    player.predictKbDmg += 35;
            }
        }
    }

        // DECEL
        const decel = Math.pow(config.playerDecel, delta);
        this.xVel *= decel;
        this.yVel *= decel;
        if (this.xVel > -0.01 && this.xVel < 0.01) this.xVel = 0;
        if (this.yVel > -0.01 && this.yVel < 0.01) this.yVel = 0;

        // MAP BOUNDARIES
        this.x = Math.max(playerScale, Math.min(config.mapScale - playerScale, this.x));
        this.y = Math.max(playerScale, Math.min(config.mapScale - playerScale, this.y));

        if (isMyPlayer) {
            const predictedWeapon = weapon.predictWeapon;
            const reloadArray = predictedWeapon < 9 ? player.primaryReload : player.secondaryReload;
            if (autogather.state && reloadArray === 1) {
                this.slowMult -= items.weapons[predictedWeapon].hitSlow || 0.3;
                if (this.slowMult < 0) this.slowMult = 0;
            }
        }
    }
}

